---
import BrowserChrome from './BrowserChrome.astro';
import MockupContent from './MockupContent.astro';

interface Props {
  url: string;
  gradient: string;
  tag: string;
  showOutlineBtn?: boolean;
  cardColors: string[];
  industry: string;
  title: string;
  description: string;
}

const { url, gradient, tag, showOutlineBtn = false, cardColors, industry, title, description } = Astro.props;
---

<div class="group bg-white rounded-2xl overflow-hidden border border-border hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.09)] transition-all duration-300 cursor-default">
  <div class="p-4 pb-0">
    <BrowserChrome url={url} />
    <MockupContent gradient={gradient} tag={tag} showOutlineBtn={showOutlineBtn} cardColors={cardColors} />
  </div>
  <div class="p-6">
    <span class="inline-block bg-light text-primary text-[0.7rem] font-bold px-3 py-1 rounded-full mb-3 uppercase tracking-wide">
      {industry}
    </span>
    <h3 class="text-dark font-bold text-base mb-2">{title}</h3>
    <p class="text-muted text-sm leading-relaxed">{description}</p>
  </div>
</div>
