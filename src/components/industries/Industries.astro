---
const industries = [
  {
    id: 'professional-services',
    label: 'Professional Services',
    tagline: 'Law firms, consultancies & accounting practices that win on credibility.',
    gradient: 'linear-gradient(160deg, #0a1020 0%, #1e3a8a 55%, #2563eb 100%)',
    accent: '#3b82f6',
    video: '/videos/professional-services.mp4',
    size: 'lg',
  },
  {
    id: 'technology-it',
    label: 'Technology & IT',
    tagline: 'SaaS platforms, MSPs & cybersecurity firms.',
    gradient: 'linear-gradient(160deg, #10071e 0%, #4c1d95 55%, #7c3aed 100%)',
    accent: '#8b5cf6',
    video: '/videos/technology-it.mp4',
    size: 'md',
  },
  {
    id: 'construction-engineering',
    label: 'Construction & Engineering',
    tagline: 'Commercial builders, architects & facilities.',
    gradient: 'linear-gradient(160deg, #140a04 0%, #7c2d12 55%, #ea580c 100%)',
    accent: '#f97316',
    video: '/videos/construction-engineering.mp4',
    size: 'sm',
  },
  {
    id: 'marketing-creative',
    label: 'Marketing & Creative',
    tagline: 'Digital agencies, branding studios & video production.',
    gradient: 'linear-gradient(160deg, #071410 0%, #064e3b 55%, #059669 100%)',
    accent: '#10b981',
    video: '/videos/marketing-creative.mp4',
    size: 'sm',
  },
  {
    id: 'finance-advisory',
    label: 'Finance & Advisory',
    tagline: 'Lenders, wealth managers & insurance brokers.',
    gradient: 'linear-gradient(160deg, #04101a 0%, #164e63 55%, #0891b2 100%)',
    accent: '#06b6d4',
    video: '/videos/finance-advisory.mp4',
    size: 'sm',
  },
];
---

<section
  class="relative py-28 overflow-hidden text-white"
  id="industries"
  style="background: radial-gradient(ellipse at 50% 0%, #2a2b6e 0%, #1a1b4b 40%, #0f1024 100%);"
>
  <!-- Dot grid texture -->
  <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>

  <!-- Aurora accents -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(109,40,217,0.18) 0%, transparent 70%); filter: blur(80px);"></div>
  <div class="absolute bottom-0 right-0 w-[700px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(20,184,166,0.10) 0%, transparent 70%); filter: blur(70px);"></div>

  <div class="relative max-w-[1240px] mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-12">
      <div class="max-w-[620px]">
        <div class="inline-flex items-center gap-2 bg-white/8 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-6 backdrop-blur-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
          Industry Expertise
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1] mb-5">
          Built for the way<br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #93c5fd, #a5b4fc);">B2B clients actually buy.</span>
        </h2>
        <p class="text-white/60 text-base sm:text-lg leading-relaxed font-medium">
          Every sector evaluates differently. We design for how your clients search, compare, and decide — not a template that fits nobody.
        </p>
      </div>

      <a
        href="/industry-showcase"
        class="shrink-0 hidden lg:inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm border border-white/20 text-white hover:border-white/50 hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200 cursor-pointer"
      >
        View full showcase
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-5" id="industry-grid">
      {industries.map((industry, idx) => {
        const colSpan =
          industry.size === 'lg' ? 'md:col-span-4' :
          industry.size === 'md' ? 'md:col-span-2' :
          'md:col-span-2';
        const rowHeight =
          industry.size === 'lg' ? 'h-[340px] md:h-[420px]' :
          industry.size === 'md' ? 'h-[220px] md:h-[420px]' :
          'h-[220px] md:h-[260px]';

        return (
          <a
            href={`/industry/${industry.id}`}
            class={`industry-card group relative rounded-2xl overflow-hidden block ${colSpan} ${rowHeight} border border-white/5 hover:border-white/20 transition-all duration-300`}
            data-accent={industry.accent}
            aria-label={`Explore ${industry.label} websites`}
          >
            <!-- Base gradient -->
            <div class="absolute inset-0" style={`background: ${industry.gradient};`}></div>

            <!-- Subtle noise -->
            <div class="absolute inset-0 opacity-[0.035] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox%3D%220 0 200 200%22 xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cfilter id%3D%22n%22%3E%3CfeTurbulence type%3D%22fractalNoise%22 baseFrequency%3D%220.9%22 numOctaves%3D%224%22 stitchTiles%3D%22stitch%22%2F%3E%3C%2Ffilter%3E%3Crect width%3D%22100%25%22 height%3D%22100%25%22 filter%3D%22url(%23n)%22%2F%3E%3C%2Fsvg%3E'); background-size: 180px 180px;"></div>

            <!-- Video preview -->
            <video
              class="industry-video absolute inset-0 w-full h-full object-cover opacity-30 transition-opacity duration-500"
              muted
              playsinline
              loop
              preload="metadata"
              src={industry.video}
              data-src={industry.video}
            ></video>

            <!-- Darkening gradient so text stays legible -->
            <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.25) 50%, rgba(0,0,0,0.05) 100%);"></div>

            <!-- Accent glow on hover -->
            <div
              class="industry-glow absolute inset-0 opacity-0 transition-opacity duration-500 pointer-events-none"
              style={`background: radial-gradient(ellipse at 50% 110%, ${industry.accent}55 0%, transparent 65%);`}
            ></div>

            <!-- Large index watermark -->
            <div class="absolute top-4 right-5 select-none pointer-events-none">
              <span class="font-black text-[44px] md:text-[56px] leading-none tabular-nums" style="color: rgba(255,255,255,0.08);">
                {String(idx + 1).padStart(2, '0')}
              </span>
            </div>

            <!-- Content -->
            <div class="absolute inset-0 flex flex-col justify-end p-5 md:p-6">
              <!-- Accent underline stripe — grows on hover -->
              <div
                class="industry-stripe h-[2px] mb-4 transition-all duration-500"
                style={`background: ${industry.accent}; width: 28px;`}
              ></div>

              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <!-- Badge -->
                  <span
                    class="inline-block text-[9px] font-bold uppercase tracking-[0.18em] px-2.5 py-1 rounded-full mb-3"
                    style={`background: ${industry.accent}22; color: ${industry.accent}; border: 1px solid ${industry.accent}40;`}
                  >
                    B2B
                  </span>

                  <!-- Label -->
                  <h3 class={`text-white font-bold leading-snug ${industry.size === 'lg' ? 'text-xl md:text-2xl' : 'text-base md:text-lg'} mb-1.5`}>
                    {industry.label}
                  </h3>

                  <!-- Tagline -->
                  <p class={`industry-tagline text-white/60 text-xs md:text-sm leading-relaxed md:opacity-0 md:translate-y-2 transition-all duration-400 ${industry.size === 'lg' ? 'md:max-w-[380px]' : 'md:max-w-[260px]'}`}>
                    {industry.tagline}
                  </p>
                </div>

                <!-- Arrow button -->
                <div
                  class="industry-arrow shrink-0 w-9 h-9 rounded-full flex items-center justify-center border transition-all duration-300 mt-1"
                  style={`border-color: ${industry.accent}55; color: ${industry.accent}; background: ${industry.accent}12;`}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Mobile CTA -->
    <div class="lg:hidden mt-10 text-center">
      <a
        href="/industry-showcase"
        class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-sm border border-white/20 text-white hover:border-white/50 hover:bg-white/5 transition-all duration-200 cursor-pointer"
      >
        View full showcase
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<script is:inline>
(() => {
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = () => window.matchMedia('(min-width: 768px)').matches;
  const cards = document.querySelectorAll('#industry-grid .industry-card');

  cards.forEach((card) => {
    const video = card.querySelector('.industry-video');
    const glow = card.querySelector('.industry-glow');
    const stripe = card.querySelector('.industry-stripe');
    const tagline = card.querySelector('.industry-tagline');
    const arrow = card.querySelector('.industry-arrow');
    const accent = card.dataset.accent;

    card.addEventListener('mouseenter', () => {
      if (!isDesktop()) return;
      if (video && video.dataset.src && !reducedMotion) {
        video.currentTime = 0;
        video.play().catch(() => {});
      }
      if (video) video.style.opacity = '0.75';
      if (glow) glow.style.opacity = '1';
      if (stripe) stripe.style.width = '64px';
      if (tagline) {
        tagline.style.opacity = '1';
        tagline.style.transform = 'translateY(0)';
      }
      if (arrow) {
        arrow.style.background = accent;
        arrow.style.color = '#ffffff';
        arrow.style.borderColor = accent;
      }
    });

    card.addEventListener('mouseleave', () => {
      if (!isDesktop()) return;
      if (video) {
        video.pause();
        video.style.opacity = '0.3';
      }
      if (glow) glow.style.opacity = '0';
      if (stripe) stripe.style.width = '28px';
      if (tagline) {
        tagline.style.opacity = '';
        tagline.style.transform = '';
      }
      if (arrow) {
        arrow.style.background = `${accent}12`;
        arrow.style.color = accent;
        arrow.style.borderColor = `${accent}55`;
      }
    });
  });

  // Stagger fade-in on scroll into view
  if (!reducedMotion && 'IntersectionObserver' in window) {
    cards.forEach((card, idx) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(24px)';
      card.style.transition = `opacity 0.6s ease-out ${idx * 60}ms, transform 0.6s ease-out ${idx * 60}ms, border-color 0.3s`;
    });
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    cards.forEach((card) => io.observe(card));
  }
})();
</script>
