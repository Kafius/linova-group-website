---

<section class="py-8 bg-[#f8fafc]" id="clients">
  <div class="max-w-[1140px] mx-auto px-6">
    <h2 class="text-center text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-muted/70 mb-5">Trusted by growing businesses</h2>
    <ul class="grid grid-cols-2 sm:grid-cols-4 gap-4 items-center justify-items-center list-none">
      {clients.map((client) => (
        <li class="w-full flex items-center justify-center">
          <a
            href={client.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Visit ${client.name}`}
            class:list={[
              "flex items-center justify-center w-full px-4 grayscale opacity-40 hover:grayscale-0 hover:opacity-80 transition-all duration-400 cursor-pointer",
              client.height
            ]}
          >
            <img src={client.logo} alt={client.name} loading="lazy" decoding="async" class="max-h-full max-w-full object-contain mix-blend-multiply" />
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
