---
const bullets = [
  { title: 'Track real-time visitors', desc: "See who's on your site right now, what page they're on, and where they came from." },
  { title: 'Understand your audience', desc: 'Demographics, location, device type — know your customers better than ever.' },
  { title: 'Measure what matters', desc: 'Button clicks, form submissions, calls — we set up key event tracking for you.' },
  { title: 'Grow with confidence', desc: "Make data-driven decisions instead of guessing what's working." },
];
---

<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-[1140px] mx-auto px-6">

    <!-- Header -->
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Built-In Analytics</span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark tracking-tight mb-5 leading-tight">
          Know Exactly Who's<br />Visiting Your Website
        </h2>
        <p class="text-muted text-lg leading-relaxed mb-8">
          Every site we build comes with Google Analytics fully configured — so from day one you can see who's visiting, where they're coming from, and what's converting.
        </p>

        <ul class="flex flex-col gap-4 mb-10">
          {bullets.map(({ title, desc }) => (
            <li class="flex gap-3">
              <div class="w-5 h-5 rounded-full bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <div class="text-dark font-semibold text-sm">{title}</div>
                <div class="text-muted text-sm mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-primary text-white hover:bg-primary-hover hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(38,39,94,0.25)] transition-all duration-200 cursor-pointer">
          Get Analytics Set Up
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right: GA dashboard mockup -->
      <div class="relative">
        <!-- Glow -->
        <div class="absolute -inset-4 bg-primary/5 rounded-3xl blur-2xl pointer-events-none"></div>

        <!-- Browser chrome -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-border">

          <!-- Chrome bar -->
          <div class="bg-[#f1f3f4] border-b border-border px-4 py-2.5 flex items-center gap-2.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
            <div class="flex-1 bg-white rounded px-3 py-1 text-[0.65rem] text-muted ml-1">analytics.google.com</div>
          </div>

          <!-- GA UI -->
          <div class="bg-white">

            <!-- GA top bar -->
            <div class="bg-white border-b border-border px-5 py-3 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <!-- Google Analytics logo mark -->
                <svg width="22" height="22" viewBox="0 0 192 192" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="192" height="192" rx="96" fill="#E37400"/>
                  <path d="M130 154V65c0-8.284 6.716-15 15-15s15 6.716 15 15v89c0 8.284-6.716 15-15 15s-15-6.716-15-15z" fill="white"/>
                  <path d="M77 154V112c0-8.284 6.716-15 15-15s15 6.716 15 15v42c0 8.284-6.716 15-15 15s-15-6.716-15-15z" fill="white" opacity="0.8"/>
                  <circle cx="47" cy="147" r="15" fill="white" opacity="0.6"/>
                </svg>
                <div>
                  <div class="text-[9px] text-muted leading-none">Your Business Name</div>
                  <div class="text-xs font-semibold text-dark leading-none mt-0.5">Analytics</div>
                </div>
              </div>
              <div class="text-[10px] text-muted bg-light px-3 py-1 rounded-full border border-border">Last 28 days</div>
            </div>

            <div class="p-5">

              <!-- Report title -->
              <div class="text-sm font-bold text-dark mb-4">Reports snapshot</div>

              <!-- Stat cards -->
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
                {[
                  { label: 'Active Users', value: '2,847', change: '+18%', up: true },
                  { label: 'New Users', value: '1,932', change: '+24%', up: true },
                  { label: 'Avg. Session', value: '2m 14s', change: '+6%', up: true },
                  { label: 'Event Count', value: '14,201', change: '+31%', up: true },
                ].map(stat => (
                  <div class="border border-border rounded-lg p-3">
                    <div class="text-[9.5px] text-muted mb-1">{stat.label}</div>
                    <div class="text-base font-bold text-dark leading-none mb-1">{stat.value}</div>
                    <div class={`text-[9px] font-semibold ${stat.up ? 'text-green-600' : 'text-red-500'}`}>{stat.change}</div>
                  </div>
                ))}
              </div>

              <!-- Chart + table row -->
              <div class="grid grid-cols-1 sm:grid-cols-5 gap-3 mb-3">

                <!-- Users over time chart -->
                <div class="sm:col-span-3 border border-border rounded-lg p-3">
                  <div class="text-[10px] font-semibold text-dark mb-3">Active users over time</div>
                  <!-- SVG line chart -->
                  <svg viewBox="0 0 260 70" class="w-full" preserveAspectRatio="none">
                    <!-- Grid lines -->
                    <line x1="0" y1="17" x2="260" y2="17" stroke="#f1f5f9" stroke-width="1"/>
                    <line x1="0" y1="35" x2="260" y2="35" stroke="#f1f5f9" stroke-width="1"/>
                    <line x1="0" y1="52" x2="260" y2="52" stroke="#f1f5f9" stroke-width="1"/>
                    <!-- Area fill -->
                    <path d="M0,55 C15,50 25,45 40,38 C55,31 65,42 80,35 C95,28 105,20 120,18 C135,16 145,28 160,22 C175,16 185,8 200,10 C215,12 225,20 240,15 C248,12 255,8 260,6 L260,70 L0,70 Z" fill="#3b82f6" fill-opacity="0.08"/>
                    <!-- Line -->
                    <path d="M0,55 C15,50 25,45 40,38 C55,31 65,42 80,35 C95,28 105,20 120,18 C135,16 145,28 160,22 C175,16 185,8 200,10 C215,12 225,20 240,15 C248,12 255,8 260,6" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <!-- Dots -->
                    <circle cx="40" cy="38" r="2.5" fill="#3b82f6"/>
                    <circle cx="80" cy="35" r="2.5" fill="#3b82f6"/>
                    <circle cx="120" cy="18" r="2.5" fill="#3b82f6"/>
                    <circle cx="160" cy="22" r="2.5" fill="#3b82f6"/>
                    <circle cx="200" cy="10" r="2.5" fill="#3b82f6"/>
                    <circle cx="240" cy="15" r="2.5" fill="#3b82f6"/>
                  </svg>
                  <!-- X-axis labels -->
                  <div class="flex justify-between mt-1 px-1">
                    {['Mar 12','Mar 19','Mar 26','Apr 2','Apr 8'].map(d => (
                      <span class="text-[8px] text-muted">{d}</span>
                    ))}
                  </div>
                </div>

                <!-- Traffic sources -->
                <div class="sm:col-span-2 border border-border rounded-lg p-3">
                  <div class="text-[10px] font-semibold text-dark mb-3">Sessions by source</div>
                  <div class="flex flex-col gap-2">
                    {[
                      { source: 'Organic Search', pct: 72, sessions: '1,842' },
                      { source: 'Direct', pct: 48, sessions: '812' },
                      { source: 'Referral', pct: 30, sessions: '412' },
                      { source: 'Social', pct: 18, sessions: '201' },
                    ].map(s => (
                      <div>
                        <div class="flex justify-between mb-0.5">
                          <span class="text-[9px] text-muted truncate">{s.source}</span>
                          <span class="text-[9px] font-semibold text-dark ml-2 flex-shrink-0">{s.sessions}</span>
                        </div>
                        <div class="h-1.5 bg-light rounded-full overflow-hidden">
                          <div class="h-full bg-primary rounded-full" style={`width:${s.pct}%`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Top pages -->
              <div class="border border-border rounded-lg p-3">
                <div class="text-[10px] font-semibold text-dark mb-2">Top pages</div>
                <div class="grid grid-cols-4 gap-2 text-[8.5px] text-muted font-semibold uppercase tracking-wider pb-1 border-b border-border">
                  <div class="col-span-2">Page</div>
                  <div class="text-right">Views</div>
                  <div class="text-right">Bounce rate</div>
                </div>
                {[
                  { page: '/ (Home)', views: '1,204', bounce: '32%' },
                  { page: '/services', views: '847', bounce: '28%' },
                  { page: '/contact', views: '521', bounce: '19%' },
                  { page: '/about', views: '275', bounce: '41%' },
                ].map((row, i) => (
                  <div class={`grid grid-cols-4 gap-2 py-1.5 text-[9px] ${i < 3 ? 'border-b border-border/60' : ''}`}>
                    <div class="col-span-2 text-dark font-medium">{row.page}</div>
                    <div class="text-right text-muted">{row.views}</div>
                    <div class="text-right text-green-600 font-semibold">{row.bounce}</div>
                  </div>
                ))}
              </div>

            </div>
          </div>
        </div>

        <!-- "Included free" badge -->
        <div class="absolute -bottom-4 -right-4 bg-primary text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg">
          Optional add-on
        </div>
      </div>
    </div>
  </div>
</section>
