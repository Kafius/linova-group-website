---
const bullets = [
  { title: 'Full-screen video backgrounds', desc: 'Autoplaying, looping video that immediately pulls visitors into your brand world.' },
  { title: 'Animated text & scroll effects', desc: 'Headlines that fade in, slide up, and react to scroll — making every visit feel alive.' },
  { title: 'Optimised for performance', desc: 'Compressed, lazy-loaded assets so your hero looks stunning without killing load times.' },
  { title: 'Mobile-first motion', desc: 'Graceful fallbacks ensure the experience is seamless on every device.' },
];
---

<section class="py-24 overflow-hidden" style="background: linear-gradient(160deg, #07080f 0%, #0f1020 60%, #0a0d1a 100%);">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-pink-400/80 mb-3">Cinematic Heroes</span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white tracking-tight mb-5 leading-tight">
          A Hero That Stops<br />the Scroll
        </h2>
        <p class="text-white/55 text-lg leading-relaxed mb-8">
          Your hero section is the first thing every visitor sees. We build cinematic, motion-driven heroes that set the tone for your brand in the first three seconds — and make people want to keep reading.
        </p>

        <ul class="flex flex-col gap-4 mb-10">
          {bullets.map(({ title, desc }) => (
            <li class="flex gap-3">
              <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: rgba(236,72,153,0.15);">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <div class="text-white font-semibold text-sm">{title}</div>
                <div class="text-white/45 text-sm mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(236,72,153,0.3)] transition-all duration-200 cursor-pointer" style="background: linear-gradient(135deg, #db2777, #9333ea);">
          Add a Cinematic Hero
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right: hero mockup -->
      <div class="relative">
        <!-- Outer glow -->
        <div class="absolute -inset-4 rounded-3xl pointer-events-none" style="background: radial-gradient(ellipse at 50% 50%, rgba(236,72,153,0.12) 0%, transparent 70%); filter: blur(24px);"></div>

        <!-- Browser chrome -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10">

          <!-- Chrome bar -->
          <div class="px-4 py-2.5 flex items-center gap-2.5" style="background:#1a1b2e; border-bottom: 1px solid rgba(255,255,255,0.07);">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span>
            <div class="flex-1 rounded px-3 py-1 text-[0.65rem] ml-1" style="background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.35);">yourclient.com</div>
          </div>

          <!-- Cinematic hero mockup -->
          <div class="relative overflow-hidden" style="aspect-ratio: 16/10; background: linear-gradient(160deg, #0a0510 0%, #1a0a2e 40%, #0d1a3a 100%);">

            <!-- Animated gradient orbs -->
            <div class="absolute rounded-full pointer-events-none" style="width:340px;height:280px;top:-60px;left:-80px;background:radial-gradient(ellipse,rgba(147,51,234,0.35) 0%,transparent 70%);filter:blur(40px);"></div>
            <div class="absolute rounded-full pointer-events-none" style="width:280px;height:240px;bottom:-40px;right:-60px;background:radial-gradient(ellipse,rgba(236,72,153,0.28) 0%,transparent 70%);filter:blur(35px);"></div>
            <div class="absolute rounded-full pointer-events-none" style="width:200px;height:180px;top:30%;left:50%;transform:translateX(-50%);background:radial-gradient(ellipse,rgba(59,130,246,0.2) 0%,transparent 70%);filter:blur(30px);"></div>

            <!-- Subtle grid overlay -->
            <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>

            <!-- Faint horizontal scan line -->
            <div class="absolute inset-x-0 pointer-events-none" style="top:38%;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.06),transparent);"></div>

            <!-- Navbar inside mockup -->
            <div class="absolute inset-x-0 top-0 flex items-center justify-between px-6 py-3" style="border-bottom:1px solid rgba(255,255,255,0.07);">
              <div class="flex items-center gap-1.5">
                <div class="w-4 h-4 rounded" style="background:linear-gradient(135deg,#db2777,#7c3aed);"></div>
                <div class="w-12 h-2 rounded-full" style="background:rgba(255,255,255,0.25);"></div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-8 h-1.5 rounded-full" style="background:rgba(255,255,255,0.15);"></div>
                <div class="w-8 h-1.5 rounded-full" style="background:rgba(255,255,255,0.15);"></div>
                <div class="w-8 h-1.5 rounded-full" style="background:rgba(255,255,255,0.15);"></div>
                <div class="px-2.5 py-1 rounded-md text-[8px] font-bold" style="background:linear-gradient(135deg,#db2777,#7c3aed);color:white;">Get Started</div>
              </div>
            </div>

            <!-- Hero content -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
              <!-- Eyebrow pill -->
              <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full mb-4" style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);">
                <div class="w-1.5 h-1.5 rounded-full" style="background:#ec4899;"></div>
                <span class="text-[8px] font-bold uppercase tracking-widest" style="color:rgba(255,255,255,0.6);">Award-Winning Agency</span>
              </div>

              <!-- Headline lines -->
              <div class="w-48 h-3.5 rounded-full mb-2" style="background:linear-gradient(90deg,rgba(255,255,255,0.85),rgba(255,255,255,0.6));"></div>
              <div class="w-36 h-3.5 rounded-full mb-1" style="background:linear-gradient(90deg,rgba(236,72,153,0.9),rgba(147,51,234,0.8));"></div>

              <!-- Sub line -->
              <div class="w-40 h-2 rounded-full mt-3 mb-5" style="background:rgba(255,255,255,0.2);"></div>

              <!-- CTAs -->
              <div class="flex items-center gap-2">
                <div class="px-4 py-1.5 rounded-lg text-[8px] font-bold" style="background:linear-gradient(135deg,#db2777,#7c3aed);color:white;">Get a Free Quote</div>
                <div class="px-4 py-1.5 rounded-lg text-[8px] font-semibold" style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);">View Our Work</div>
              </div>
            </div>

            <!-- Play button overlay (implies video) -->
            <div class="absolute bottom-4 right-4 flex items-center gap-1.5 px-2.5 py-1.5 rounded-full" style="background:rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.12);backdrop-filter:blur(6px);">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="white" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <span class="text-[8px] font-semibold" style="color:rgba(255,255,255,0.75);">Watch reel</span>
            </div>

            <!-- Scroll indicator -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1">
              <div class="w-3.5 h-5 rounded-full flex items-start justify-center pt-1" style="border:1px solid rgba(255,255,255,0.2);">
                <div class="w-0.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></div>
              </div>
            </div>

          </div>
        </div>

        <!-- "Motion-driven" badge -->
        <div class="absolute -bottom-4 -right-4 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg" style="background:linear-gradient(135deg,#db2777,#7c3aed);">
          Motion-driven
        </div>
      </div>

    </div>
  </div>
</section>
