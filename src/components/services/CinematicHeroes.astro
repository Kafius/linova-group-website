---
const bullets = [
  { title: 'Full-screen video backgrounds', desc: 'Autoplaying, looping video that immediately pulls visitors into your brand world.' },
  { title: 'Animated text & scroll effects', desc: 'Headlines that fade in, slide up, and react to scroll — making every visit feel alive.' },
  { title: 'Optimised for performance', desc: 'Compressed, lazy-loaded assets so your hero looks stunning without killing load times.' },
  { title: 'Mobile-first motion', desc: 'Graceful fallbacks ensure the experience is seamless on every device.' },
];
---

<section id="cinematic-heroes" class="py-24 bg-[#f8fafc] overflow-hidden">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-pink-600 mb-3">Cinematic Heroes</span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark tracking-tight mb-5 leading-tight">
          A Hero That Stops<br />the Scroll
        </h2>
        <p class="text-muted text-lg leading-relaxed mb-8">
          Your hero section is the first thing every visitor sees. We build cinematic, motion-driven heroes that set the tone for your brand in the first three seconds — and make people want to keep reading.
        </p>

        <ul class="flex flex-col gap-4 mb-10">
          {bullets.map(({ title, desc }) => (
            <li class="flex gap-3">
              <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: rgba(219,39,119,0.1);">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#db2777" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <div class="text-dark font-semibold text-sm">{title}</div>
                <div class="text-muted text-sm mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(236,72,153,0.3)] transition-all duration-200 cursor-pointer" style="background: linear-gradient(135deg, #db2777, #9333ea);">
          Add a Cinematic Hero
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right: live cinematic hero example -->
      <div class="relative">
        <!-- Outer glow -->
        <div class="absolute -inset-4 rounded-3xl pointer-events-none" style="background: radial-gradient(ellipse at 50% 50%, rgba(219,39,119,0.08) 0%, transparent 70%); filter: blur(24px);"></div>

        <!-- Browser chrome -->
        <div class="relative rounded-2xl overflow-hidden shadow-[0_8px_40px_rgba(0,0,0,0.12)] border border-border">

          <!-- Chrome bar -->
          <div class="px-4 py-2.5 flex items-center gap-2.5 bg-white border-b border-border">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span>
            <div class="flex-1 rounded px-3 py-1 text-[0.65rem] ml-1 bg-light text-muted">yourclient.com</div>
          </div>

          <!-- Live cinematic hero with video background -->
          <div class="relative overflow-hidden" style="aspect-ratio: 16/10;">

            <!-- Video background -->
            <video
              class="absolute inset-0 w-full h-full object-cover"
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
            >
              <source src="/videos/cinematic-heroes.mp4" type="video/mp4" />
            </video>

            <!-- Dark overlay for text readability -->
            <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.5) 100%);"></div>

            <!-- Navbar inside mockup -->
            <div class="absolute inset-x-0 top-0 z-10 flex items-center justify-between px-6 py-3" style="border-bottom:1px solid rgba(255,255,255,0.1);">
              <div class="flex items-center gap-1.5">
                <div class="w-4 h-4 rounded" style="background:linear-gradient(135deg,#db2777,#7c3aed);"></div>
                <div class="w-12 h-2 rounded-full" style="background:rgba(255,255,255,0.3);"></div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-8 h-1.5 rounded-full" style="background:rgba(255,255,255,0.2);"></div>
                <div class="w-8 h-1.5 rounded-full" style="background:rgba(255,255,255,0.2);"></div>
                <div class="w-8 h-1.5 rounded-full" style="background:rgba(255,255,255,0.2);"></div>
                <div class="px-2.5 py-1 rounded-md text-[8px] font-bold" style="background:linear-gradient(135deg,#db2777,#7c3aed);color:white;">Get Started</div>
              </div>
            </div>

            <!-- Hero content overlay -->
            <div class="absolute inset-0 z-10 flex flex-col items-center justify-center text-center px-6">
              <!-- Eyebrow pill -->
              <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full mb-4" style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);backdrop-filter:blur(8px);">
                <div class="w-1.5 h-1.5 rounded-full" style="background:#ec4899;"></div>
                <span class="text-[8px] font-bold uppercase tracking-widest" style="color:rgba(255,255,255,0.8);">Award-Winning Agency</span>
              </div>

              <!-- Headline -->
              <h3 class="text-white font-extrabold text-sm sm:text-base leading-tight mb-1 drop-shadow-lg">
                We Build Brands
              </h3>
              <h3 class="font-extrabold text-sm sm:text-base leading-tight mb-3 drop-shadow-lg" style="background:linear-gradient(90deg,#ec4899,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                That Move People
              </h3>

              <!-- Sub line -->
              <p class="text-[9px] sm:text-[10px] max-w-[220px] leading-relaxed mb-5 drop-shadow" style="color:rgba(255,255,255,0.7);">
                Cinematic experiences that captivate your audience from the very first frame.
              </p>

              <!-- CTAs -->
              <div class="flex items-center gap-2">
                <div class="px-4 py-1.5 rounded-lg text-[8px] font-bold shadow-lg" style="background:linear-gradient(135deg,#db2777,#7c3aed);color:white;">Get a Free Quote</div>
                <div class="px-4 py-1.5 rounded-lg text-[8px] font-semibold" style="border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.85);backdrop-filter:blur(4px);">View Our Work</div>
              </div>
            </div>

            <!-- Scroll indicator -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1">
              <div class="w-3.5 h-5 rounded-full flex items-start justify-center pt-1" style="border:1px solid rgba(255,255,255,0.3);">
                <div class="w-0.5 h-1.5 rounded-full animate-bounce" style="background:rgba(255,255,255,0.6);"></div>
              </div>
            </div>

          </div>
        </div>

        <!-- "Motion-driven" badge -->
        <div class="absolute -bottom-4 -right-4 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg" style="background:linear-gradient(135deg,#db2777,#7c3aed);">
          Motion-driven
        </div>
      </div>

    </div>
  </div>
</section>
