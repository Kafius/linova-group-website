---
const bullets = [
  { title: 'Submit requests any time', desc: 'Need a new page, a copy update, or a design tweak? Log it in the portal and we handle the rest.' },
  { title: 'Track every change', desc: 'See exactly what\'s in progress, what\'s been completed, and what\'s coming next — no chasing required.' },
  { title: 'Priority turnaround', desc: 'Maintenance clients jump the queue. Most requests are turned around within 24–48 hours.' },
  { title: 'Security & uptime included', desc: 'We monitor your site around the clock and push updates before issues become problems.' },
];

const requests = [
  { id: '#1042', title: 'Update homepage headline copy', type: 'Content', status: 'Completed', statusColor: 'green', date: 'Apr 14' },
  { id: '#1041', title: 'Add new team member to About page', type: 'Content', status: 'Completed', statusColor: 'green', date: 'Apr 11' },
  { id: '#1043', title: 'New service section — Cinematic Heroes', type: 'Design', status: 'In Progress', statusColor: 'blue', date: 'Apr 17' },
  { id: '#1044', title: 'Fix mobile nav overlap on iOS Safari', type: 'Bug Fix', status: 'In Review', statusColor: 'amber', date: 'Apr 17' },
];
---

<section class="py-24 overflow-hidden" style="background: #f8fafc;">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-cyan-600/80 mb-3">Maintenance & Support</span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark tracking-tight mb-5 leading-tight">
          We Don't Just Build It<br />and Disappear
        </h2>
        <p class="text-muted text-lg leading-relaxed mb-8">
          Maintenance clients get access to a dedicated request portal. Need something changed on your site? Submit it, track it, and watch it get done — without a single back-and-forth email.
        </p>

        <ul class="flex flex-col gap-4 mb-10">
          {bullets.map(({ title, desc }) => (
            <li class="flex gap-3">
              <div class="w-5 h-5 rounded-full bg-cyan-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <div class="text-dark font-semibold text-sm">{title}</div>
                <div class="text-muted text-sm mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(6,182,212,0.3)] transition-all duration-200 cursor-pointer" style="background: linear-gradient(135deg, #0891b2, #06b6d4);">
          Get a Maintenance Package
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right: booking portal mockup -->
      <div class="relative">
        <!-- Glow -->
        <div class="absolute -inset-4 rounded-3xl pointer-events-none" style="background: radial-gradient(ellipse at 50% 50%, rgba(6,182,212,0.08) 0%, transparent 70%); filter: blur(24px);"></div>

        <!-- Browser chrome -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-border">

          <!-- Chrome bar -->
          <div class="bg-[#f1f3f4] border-b border-border px-4 py-2.5 flex items-center gap-2.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
            <div class="flex-1 bg-white rounded px-3 py-1 text-[0.65rem] text-muted ml-1">portal.linovagroup.com.au</div>
          </div>

          <!-- Portal UI -->
          <div class="bg-white flex" style="min-height: 380px;">

            <!-- Sidebar -->
            <div class="hidden sm:flex w-[140px] flex-shrink-0 border-r border-border flex-col" style="background:#fafafa;">
              <!-- Logo -->
              <div class="px-4 py-3.5 border-b border-border flex items-center gap-2">
                <div class="w-5 h-5 rounded-md flex-shrink-0" style="background:linear-gradient(135deg,#0891b2,#26275E);"></div>
                <span class="text-[10px] font-bold text-dark">Client Portal</span>
              </div>
              <!-- Nav items -->
              <nav class="flex flex-col gap-0.5 p-2 flex-1">
                {[
                  { label: 'Dashboard', active: false, icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
                  { label: 'My Requests', active: true, icon: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2' },
                  { label: 'New Request', active: false, icon: 'M12 5v14M5 12h14' },
                  { label: 'Documents', active: false, icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z' },
                ].map(item => (
                  <div class={`flex items-center gap-2 px-2.5 py-2 rounded-lg cursor-pointer ${item.active ? 'bg-primary text-white' : 'text-muted hover:bg-light'}`}>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={item.icon}/>
                    </svg>
                    <span class="text-[9.5px] font-medium">{item.label}</span>
                  </div>
                ))}
              </nav>
              <!-- User -->
              <div class="p-3 border-t border-border flex items-center gap-2">
                <div class="w-6 h-6 rounded-full bg-cyan-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-[8px] font-bold text-cyan-700">JD</span>
                </div>
                <div>
                  <div class="text-[8.5px] font-semibold text-dark leading-none">John D.</div>
                  <div class="text-[7.5px] text-muted">Active plan</div>
                </div>
              </div>
            </div>

            <!-- Main content -->
            <div class="flex-1 flex flex-col">

              <!-- Top bar -->
              <div class="px-5 py-3.5 border-b border-border flex items-center justify-between">
                <div>
                  <div class="text-xs font-bold text-dark">My Requests</div>
                  <div class="text-[9px] text-muted">4 total · 2 active</div>
                </div>
                <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-white text-[9px] font-bold" style="background:linear-gradient(135deg,#0891b2,#06b6d4);">
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                  New Request
                </button>
              </div>

              <!-- Request list -->
              <div class="flex-1 p-4 flex flex-col gap-2">
                {requests.map(req => (
                  <div class="flex items-center gap-3 p-3 rounded-xl border border-border hover:border-cyan-200 hover:bg-cyan-50/40 transition-colors cursor-pointer">
                    <!-- ID -->
                    <div class="hidden sm:block text-[8.5px] font-mono text-muted flex-shrink-0 w-9">{req.id}</div>
                    <!-- Title + type -->
                    <div class="flex-1 min-w-0">
                      <div class="text-[9.5px] font-semibold text-dark truncate">{req.title}</div>
                      <div class="text-[8px] text-muted mt-0.5">{req.type}</div>
                    </div>
                    <!-- Status badge -->
                    <div class={`flex-shrink-0 px-2 py-0.5 rounded-full text-[7.5px] font-bold ${
                      req.statusColor === 'green' ? 'bg-green-100 text-green-700' :
                      req.statusColor === 'blue'  ? 'bg-blue-100 text-blue-700' :
                                                    'bg-amber-100 text-amber-700'
                    }`}>
                      {req.status}
                    </div>
                    <!-- Date -->
                    <div class="hidden sm:block text-[8px] text-muted flex-shrink-0">{req.date}</div>
                  </div>
                ))}
              </div>

            </div>
          </div>
        </div>

        <!-- Badge -->
        <div class="absolute -bottom-4 -right-4 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg" style="background: linear-gradient(135deg, #0891b2, #06b6d4);">
          Client Portal
        </div>
      </div>

    </div>
  </div>
</section>
