---
const bullets = [
  { title: 'Edit any page, any time', desc: 'Update your homepage headline, swap images, or tweak pricing — all from a clean, simple dashboard.' },
  { title: 'No code. No developer needed.', desc: 'Your content editor looks and feels like a word processor. If you can type, you can manage your site.' },
  { title: 'Changes go live instantly', desc: 'Hit save and your site updates in seconds. No waiting on an agency to make a simple text change.' },
  { title: 'Your content, your control', desc: 'Blog posts, service pages, team bios, FAQs — all editable from one place.' },
];

const sidebarItems = [
  { icon: 'home', label: 'Dashboard', active: false },
  { icon: 'file', label: 'Pages', active: true },
  { icon: 'edit', label: 'Blog Posts', active: false },
  { icon: 'image', label: 'Media', active: false },
  { icon: 'settings', label: 'Settings', active: false },
];
---

<section class="py-24 bg-[#f8fafc] overflow-hidden">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: CMS mockup -->
      <div class="relative order-2 lg:order-1">
        <!-- Glow -->
        <div class="absolute -inset-4 bg-violet-500/5 rounded-3xl blur-2xl pointer-events-none"></div>

        <!-- Browser chrome -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-border">

          <!-- Chrome bar -->
          <div class="bg-[#f1f3f4] border-b border-border px-4 py-2.5 flex items-center gap-2.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
            <div class="flex-1 bg-white rounded px-3 py-1 text-[0.65rem] text-muted ml-1">yourdomain.com/keystatic</div>
          </div>

          <!-- CMS UI -->
          <div class="bg-white flex" style="min-height: 380px;">

            <!-- Sidebar -->
            <div class="hidden sm:flex w-44 bg-[#1e1e2e] flex-col flex-shrink-0">
              <!-- Brand -->
              <div class="px-4 py-4 border-b border-white/10">
                <div class="flex items-center gap-2">
                  <!-- Keystatic-style logo mark -->
                  <div class="w-6 h-6 rounded bg-violet-500 flex items-center justify-center flex-shrink-0">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </div>
                  <div>
                    <div class="text-[9px] text-white/40 leading-none">Content Manager</div>
                    <div class="text-[11px] font-bold text-white leading-none mt-0.5">Keystatic</div>
                  </div>
                </div>
              </div>

              <!-- Nav items -->
              <nav class="flex flex-col gap-0.5 p-2 flex-1">
                <!-- Dashboard -->
                <a class="flex items-center gap-2.5 px-3 py-2 rounded-md text-white/50 hover:text-white/80 cursor-pointer text-[10px] font-medium transition-colors">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  Dashboard
                </a>
                <!-- Pages - active -->
                <a class="flex items-center gap-2.5 px-3 py-2 rounded-md bg-violet-500/20 text-violet-300 cursor-pointer text-[10px] font-semibold">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  Pages
                </a>
                <!-- Blog Posts -->
                <a class="flex items-center gap-2.5 px-3 py-2 rounded-md text-white/50 hover:text-white/80 cursor-pointer text-[10px] font-medium transition-colors">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Blog Posts
                </a>
                <!-- Services -->
                <a class="flex items-center gap-2.5 px-3 py-2 rounded-md text-white/50 hover:text-white/80 cursor-pointer text-[10px] font-medium transition-colors">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                  Services
                </a>
                <!-- Team -->
                <a class="flex items-center gap-2.5 px-3 py-2 rounded-md text-white/50 hover:text-white/80 cursor-pointer text-[10px] font-medium transition-colors">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  Team
                </a>
              </nav>

              <!-- Bottom -->
              <div class="p-3 border-t border-white/10">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-violet-500/30 flex items-center justify-center text-[9px] font-bold text-violet-300">JD</div>
                  <div>
                    <div class="text-[9px] font-semibold text-white/80">Jane Doe</div>
                    <div class="text-[8px] text-white/40">Admin</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Main editor area -->
            <div class="flex-1 flex flex-col overflow-hidden">

              <!-- Top bar -->
              <div class="flex items-center justify-between px-5 py-3 border-b border-border bg-white">
                <div>
                  <div class="text-[8.5px] text-muted">Pages /</div>
                  <div class="text-[11px] font-bold text-dark">Home Page</div>
                </div>
                <div class="flex items-center gap-2">
                  <button class="text-[9px] text-muted border border-border rounded px-2.5 py-1 font-medium">Preview</button>
                  <button class="text-[9px] text-white bg-violet-500 rounded px-3 py-1 font-semibold flex items-center gap-1">
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Save
                  </button>
                </div>
              </div>

              <!-- Form fields -->
              <div class="flex-1 overflow-auto p-5 flex flex-col gap-4 bg-[#fafafa]">

                <!-- Hero Headline field -->
                <div class="bg-white rounded-lg border border-border p-4">
                  <div class="flex items-center justify-between mb-2">
                    <label class="text-[9px] font-semibold text-dark uppercase tracking-wider">Hero Headline</label>
                    <span class="text-[8px] text-muted bg-light px-1.5 py-0.5 rounded">Text</span>
                  </div>
                  <div class="border border-violet-300 rounded-md px-3 py-2 bg-white flex items-center gap-1.5">
                    <span class="text-[11px] text-dark font-medium flex-1">Premium Websites. A Fraction of the Cost.</span>
                    <!-- cursor blink -->
                    <span class="w-0.5 h-3 bg-violet-500 animate-pulse"></span>
                  </div>
                </div>

                <!-- Subheading field -->
                <div class="bg-white rounded-lg border border-border p-4">
                  <div class="flex items-center justify-between mb-2">
                    <label class="text-[9px] font-semibold text-dark uppercase tracking-wider">Subheading</label>
                    <span class="text-[8px] text-muted bg-light px-1.5 py-0.5 rounded">Text</span>
                  </div>
                  <div class="border border-border rounded-md px-3 py-2 bg-white">
                    <span class="text-[10px] text-muted">Linova Group delivers beautifully crafted, high-performance websites...</span>
                  </div>
                </div>

                <!-- Hero Image field -->
                <div class="bg-white rounded-lg border border-border p-4">
                  <div class="flex items-center justify-between mb-2">
                    <label class="text-[9px] font-semibold text-dark uppercase tracking-wider">Hero Image</label>
                    <span class="text-[8px] text-muted bg-light px-1.5 py-0.5 rounded">Image</span>
                  </div>
                  <div class="border-2 border-dashed border-border rounded-md px-4 py-3 flex items-center gap-3 bg-light/50">
                    <div class="w-10 h-10 rounded bg-border flex items-center justify-center">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                    <div>
                      <div class="text-[9px] font-semibold text-dark">hero-bg.jpg</div>
                      <div class="text-[8px] text-muted">1920 × 1080 · 214 KB</div>
                    </div>
                    <button class="ml-auto text-[8px] text-violet-500 font-semibold">Replace</button>
                  </div>
                </div>

                <!-- CTA Button Label -->
                <div class="bg-white rounded-lg border border-border p-4">
                  <div class="flex items-center justify-between mb-2">
                    <label class="text-[9px] font-semibold text-dark uppercase tracking-wider">CTA Button Label</label>
                    <span class="text-[8px] text-muted bg-light px-1.5 py-0.5 rounded">Text</span>
                  </div>
                  <div class="border border-border rounded-md px-3 py-2 bg-white">
                    <span class="text-[10px] text-dark font-medium">Get a Free Quote</span>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

        <!-- "Built in" badge -->
        <div class="absolute -bottom-4 -left-4 bg-violet-600 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg">
          Optional add-on
        </div>
      </div>

      <!-- Right: copy -->
      <div class="order-1 lg:order-2">
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Content Management</span>

        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark tracking-tight mb-5 leading-tight">
          Update Your Site<br />Without Touching Code
        </h2>
        <p class="text-muted text-lg leading-relaxed mb-8">
          We can set up Keystatic — a powerful, Git-backed CMS that lives right inside your site. You get a clean admin dashboard to edit any content yourself, any time.
        </p>

        <ul class="flex flex-col gap-4 mb-10">
          {bullets.map(({ title, desc }) => (
            <li class="flex gap-3">
              <div class="w-5 h-5 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <div class="text-dark font-semibold text-sm">{title}</div>
                <div class="text-muted text-sm mt-0.5">{desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-primary text-white hover:bg-primary-hover hover:-translate-y-0.5 hover:shadow-[0_6px_20px_rgba(38,39,94,0.25)] transition-all duration-200 cursor-pointer">
          Add a CMS to My Site
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>
