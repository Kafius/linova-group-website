---
const services = [
  {
    title: 'Custom Design & Redesign',
    description: 'Turn outdated sites into modern, high-converting experiences tailored to your brand.',
    accent: '#3b82f6',
    icon: 'sparkles',
  },
  {
    title: 'Cinematic Hero Sections',
    description: 'Motion-driven, video-backed heroes that stop the scroll in the first three seconds.',
    accent: '#db2777',
    icon: 'film',
  },
  {
    title: 'Built-in Analytics',
    description: 'Google Analytics configured day one — know who visits, from where, and what converts.',
    accent: '#06b6d4',
    icon: 'chart',
  },
  {
    title: 'Self-Serve Content Editing',
    description: 'Edit copy, images, and pages yourself through a simple CMS — no developer needed.',
    accent: '#8b5cf6',
    icon: 'edit',
  },
  {
    title: 'SEO Optimization',
    description: 'Technical groundwork and on-page SEO so you start ranking from launch, not months later.',
    accent: '#10b981',
    icon: 'search',
  },
  {
    title: 'Maintenance & Support',
    description: 'Ongoing updates, hosting, security, and a real human when something needs to change.',
    accent: '#f97316',
    icon: 'shield',
  },
];
---

<section class="relative py-24 bg-white overflow-hidden" id="services">
  <!-- Soft decorative glow -->
  <div class="absolute -top-32 -right-32 w-[520px] h-[520px] rounded-full pointer-events-none opacity-[0.5]" style="background: radial-gradient(ellipse, rgba(59,130,246,0.07) 0%, transparent 70%); filter: blur(60px);"></div>
  <div class="absolute -bottom-32 -left-32 w-[520px] h-[520px] rounded-full pointer-events-none opacity-[0.5]" style="background: radial-gradient(ellipse, rgba(139,92,246,0.06) 0%, transparent 70%); filter: blur(60px);"></div>

  <div class="relative max-w-[1140px] mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-[620px] mx-auto mb-14">
      <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">What We Build</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-dark tracking-tight leading-[1.1] mb-5">
        Everything you need to launch <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #3b82f6, #8b5cf6);">and grow</span>.
      </h2>
      <p class="text-muted text-base sm:text-lg leading-relaxed">
        Design, build, analytics, SEO, and support — one team, one monthly bill, no agency runaround.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="services-teaser-grid">
      {services.map((service) => (
        <a
          href="/services"
          class="service-teaser-card group relative block rounded-2xl bg-white border border-border p-6 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(15,23,42,0.08)] hover:border-transparent"
          data-accent={service.accent}
          aria-label={`Learn more about ${service.title}`}
        >
          <!-- Top accent stripe (grows on hover) -->
          <span
            class="service-stripe absolute top-0 left-0 h-[3px] transition-all duration-500"
            style={`background: ${service.accent}; width: 36px;`}
          ></span>

          <div class="relative">
            <!-- Icon -->
            <div
              class="service-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5 transition-all duration-300"
              style={`background: ${service.accent}15; color: ${service.accent};`}
            >
              {service.icon === 'sparkles' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/></svg>
              )}
              {service.icon === 'film' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 4v16M17 4v16M3 9h4M17 9h4M3 15h4M17 15h4"/></svg>
              )}
              {service.icon === 'chart' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-4 3 3 5-6"/></svg>
              )}
              {service.icon === 'edit' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h4L18.5 9.5a2.1 2.1 0 0 0-3-3L5 17v3z"/><path d="M13.5 6.5l3 3"/></svg>
              )}
              {service.icon === 'search' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
              )}
              {service.icon === 'shield' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              )}
            </div>

            <!-- Title -->
            <h3 class="text-dark font-bold text-lg leading-snug mb-2">{service.title}</h3>

            <!-- Description -->
            <p class="text-muted text-sm leading-relaxed mb-5">{service.description}</p>

            <!-- Learn more link -->
            <div class="flex items-center gap-1.5 text-sm font-semibold transition-all duration-300" style={`color: ${service.accent};`}>
              <span>Learn more</span>
              <svg class="service-arrow transition-transform duration-300" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/services"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-[0.95rem] bg-primary text-white hover:-translate-y-0.5 hover:shadow-[0_12px_32px_rgba(59,130,246,0.3)] transition-all duration-200 cursor-pointer"
      >
        Explore all services
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-[0.95rem] text-dark hover:text-primary transition-colors duration-200 cursor-pointer"
      >
        Or get a free quote
      </a>
    </div>

  </div>
</section>

<script is:inline>
(() => {
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cards = document.querySelectorAll('#services-teaser-grid .service-teaser-card');

  cards.forEach((card) => {
    const stripe = card.querySelector('.service-stripe');
    const icon = card.querySelector('.service-icon');
    const arrow = card.querySelector('.service-arrow');
    const accent = card.dataset.accent;

    card.addEventListener('mouseenter', () => {
      if (stripe) stripe.style.width = '100%';
      if (icon) {
        icon.style.background = accent;
        icon.style.color = '#ffffff';
      }
      if (arrow) arrow.style.transform = 'translateX(3px)';
    });

    card.addEventListener('mouseleave', () => {
      if (stripe) stripe.style.width = '36px';
      if (icon) {
        icon.style.background = `${accent}15`;
        icon.style.color = accent;
      }
      if (arrow) arrow.style.transform = '';
    });
  });

  if (!reducedMotion && 'IntersectionObserver' in window) {
    cards.forEach((card, idx) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(20px)';
      const base = card.style.transition;
      card.style.transition = `${base}, opacity 0.5s ease-out ${idx * 50}ms, transform 0.5s ease-out ${idx * 50}ms`;
    });
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    cards.forEach((card) => io.observe(card));
  }
})();
</script>
