---
---

<header class="relative pt-40 pb-28 bg-gradient-to-br from-dark to-[#1e293b] text-white text-center overflow-hidden">
  <!-- Subtle dot-grid overlay -->
  <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 28px 28px;"></div>
  <!-- Blue glow blob -->
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-20 blur-3xl pointer-events-none" style="background: radial-gradient(ellipse, #3b82f6 0%, transparent 70%);"></div>

  <div class="relative max-w-[1140px] mx-auto px-6">
    <span class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/80 font-semibold text-xs tracking-widest uppercase px-4 py-2 rounded-full mb-6 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>
      Premium Web Design
    </span>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6">
      Premium Websites.<br />A Fraction of the Cost.
    </h1>
    <p class="text-base sm:text-lg lg:text-xl text-white/65 max-w-[580px] mx-auto mb-10 leading-relaxed">
      Linova Group delivers beautifully crafted, high-performance websites — without the inflated agency price tag.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/contact" class="inline-flex items-center justify-center px-7 py-3 rounded-lg font-semibold text-[0.95rem] bg-primary text-white hover:bg-primary-hover hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(37,99,235,0.3)] transition-all duration-200">
        Get a Free Quote
      </a>
      <a href="#industries" class="inline-flex items-center justify-center px-7 py-3 rounded-lg font-semibold text-[0.95rem] border-2 border-white/30 text-white hover:border-white hover:bg-white/10 transition-all duration-200">
        See Our Work
      </a>
    </div>
  </div>
</header>
