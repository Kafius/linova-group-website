---
---

<header class="relative min-h-[100svh] md:min-h-[100dvh] flex items-center pt-36 pb-28 overflow-hidden" style="background: radial-gradient(ellipse at 50% 50%, #2a2b6e 0%, #1a1b4b 45%, #16172f 100%);">
  <!-- Dot grid texture -->
  <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>

  <!-- Aurora mesh — all centered, expanding outward -->
  <!-- Core violet burst -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(109,40,217,0.22) 0%, transparent 70%); filter: blur(80px);"></div>
  <!-- Teal ring expanding outward -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, transparent 30%, rgba(20,184,166,0.12) 55%, transparent 75%); filter: blur(60px);"></div>
  <!-- Blue ring further out -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[900px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, transparent 40%, rgba(59,130,246,0.1) 65%, transparent 80%); filter: blur(70px);"></div>
  <!-- Soft indigo center glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[300px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(139,92,246,0.18) 0%, transparent 70%); filter: blur(50px);"></div>

  <div class="relative max-w-[1140px] mx-auto px-6 w-full text-center text-white">

    <!-- Badge -->
    <div id="hero-badge" class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
      Premium Web Design Agency
    </div>

    <!-- Headline -->
    <h1 id="real-hero-h1" class="text-5xl sm:text-6xl lg:text-[4.5rem] font-extrabold tracking-tight leading-[1.07] mb-6">
      Premium Websites.<br />
      <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #93c5fd, #a5b4fc);">Powered by the future.</span>
    </h1>

    <!-- Subtext -->
    <p id="real-hero-sub" class="text-lg sm:text-xl text-white/55 max-w-[560px] mx-auto mb-10 leading-relaxed font-medium">
      Linova Group delivers beautifully crafted, high-performance websites — without the inflated agency price tag.
    </p>

    <!-- CTAs -->
    <div id="real-hero-ctas" class="flex gap-4 justify-center flex-wrap mb-20">
      <a href="/contact" class="focus-ring-dark inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-[0.95rem] bg-white text-primary hover:bg-white/90 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(255,255,255,0.2)] transition-all duration-200 cursor-pointer">
        Get a Free Quote
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#services" class="focus-ring-dark inline-flex items-center justify-center px-7 py-3.5 rounded-xl font-semibold text-[0.95rem] border border-white/25 text-white hover:border-white/50 hover:bg-white/10 transition-all duration-200 cursor-pointer">
        Browse Services
      </a>
    </div>

    <!-- Stats row -->
    <div id="hero-stats" class="max-w-[520px] mx-auto border-t border-white/10 pt-10 grid grid-cols-3">
      <div class="hero-stat-item px-4">
        <div class="text-3xl sm:text-4xl font-extrabold text-white mb-1.5">50+</div>
        <div class="text-white/45 text-sm font-medium">Projects Delivered</div>
      </div>
      <div class="hero-stat-item px-4 border-x border-white/10">
        <div class="text-3xl sm:text-4xl font-extrabold text-white mb-1.5">1–2<span class="text-2xl"> wk</span></div>
        <div class="text-white/45 text-sm font-medium">Avg. Turnaround</div>
      </div>
      <div class="hero-stat-item px-4">
        <div class="text-3xl sm:text-4xl font-extrabold text-white mb-1.5">70%</div>
        <div class="text-white/45 text-sm font-medium">Cost Savings</div>
      </div>
    </div>

  </div>
</header>
