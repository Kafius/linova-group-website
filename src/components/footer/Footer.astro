---
---

<footer class="pt-16 pb-8 border-t border-border" style="background: #16172f;">
  <style>
    .footer-link:hover { color: rgba(255,255,255,0.95) !important; }
  </style>
  <div class="max-w-[1140px] mx-auto px-6">

    <!-- Top: 3-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 mb-12">

      <!-- Brand -->
      <div>
        <a href="/" class="focus-ring-dark inline-block mb-4 cursor-pointer">
          <img src="/linova-logo-horizontal.png" alt="Linova Group" width="144" height="36" class="h-9 w-auto brightness-0 invert opacity-90" />
        </a>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.6);">
          Powered by the future.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-5" style="color: rgba(255,255,255,0.55);">Quick Links</p>
        <ul class="flex flex-col gap-3">
          <li><a href="/services" class="footer-link focus-ring-dark text-sm transition-colors duration-200 cursor-pointer" style="color: rgba(255,255,255,0.65);">Services</a></li>
          <li><a href="#industries" class="footer-link focus-ring-dark text-sm transition-colors duration-200 cursor-pointer" style="color: rgba(255,255,255,0.65);">Industries</a></li>
          <li><a href="/industry-showcase" class="footer-link focus-ring-dark text-sm transition-colors duration-200 cursor-pointer" style="color: rgba(255,255,255,0.65);">Showcase</a></li>
          <li><a href="/contact" class="footer-link focus-ring-dark text-sm transition-colors duration-200 cursor-pointer" style="color: rgba(255,255,255,0.65);">Contact</a></li>
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-5" style="color: rgba(255,255,255,0.55);">Get Started</p>
        <p class="text-sm mb-5 leading-relaxed" style="color: rgba(255,255,255,0.6);">
          Ready to elevate your online presence? Let's build something great together.
        </p>
        <a href="/contact" class="focus-ring-dark inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-semibold bg-white text-primary rounded-xl hover:bg-white/90 transition-all duration-200 cursor-pointer">
          Contact Us
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

    </div>

    <!-- Divider + Copyright -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-8" style="border-top: 1px solid rgba(255,255,255,0.12);">
      <p class="text-xs" style="color: rgba(255,255,255,0.55);">&copy; 2026 Linova Group. All rights reserved.</p>
      <p class="text-xs" style="color: rgba(255,255,255,0.5);">Premium Web Design Agency</p>
    </div>

  </div>
</footer>
