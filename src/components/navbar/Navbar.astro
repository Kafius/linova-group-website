---
---

<div class="fixed top-4 inset-x-0 z-[1000] px-4 sm:px-6" id="navbarWrapper">
  <nav class="max-w-[1140px] mx-auto bg-white/95 backdrop-blur-md rounded-2xl border border-border shadow-[0_4px_24px_rgba(0,0,0,0.07)] px-5 flex items-center justify-between h-[64px] transition-shadow duration-300" id="navbar">
    <a href="/" class="flex items-center cursor-pointer">
      <img src="/linova-logo-horizontal.png" alt="Linova Group" class="h-11" />
    </a>

    <button class="flex flex-col gap-[5px] bg-transparent border-none cursor-pointer p-2 md:hidden" id="navToggle" aria-label="Toggle navigation">
      <span class="block w-5 h-0.5 bg-dark rounded-sm transition-all duration-300 origin-center"></span>
      <span class="block w-5 h-0.5 bg-dark rounded-sm transition-all duration-300 origin-center"></span>
      <span class="block w-5 h-0.5 bg-dark rounded-sm transition-all duration-300 origin-center"></span>
    </button>

    <ul class="hidden md:flex items-center gap-7" id="navLinks">
      <li class="relative group" id="servicesDropdown">
        <a href="/services" class="flex items-center gap-1 text-muted font-medium text-sm hover:text-dark transition-colors duration-200 cursor-pointer">
          Services
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <!-- Dropdown panel -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-200" style="min-width: 230px;">
          <div class="bg-white rounded-2xl border border-border shadow-[0_8px_32px_rgba(0,0,0,0.1)] p-2 flex flex-col gap-0.5">
            <a href="/services#website-redesign" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#6366f1;"></span>
              Website Redesign
            </a>
            <a href="/services#cinematic-heroes" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#ec4899;"></span>
              Cinematic Heroes
            </a>
            <a href="/services#built-in-analytics" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#f59e0b;"></span>
              Built-in Analytics
            </a>
            <a href="/services#content-management" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#10b981;"></span>
              Content Management
            </a>
            <a href="/services#seo-optimization" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#3b82f6;"></span>
              SEO Optimization
            </a>
            <a href="/services#maintenance-support" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#06b6d4;"></span>
              Maintenance & Support
            </a>
          </div>
        </div>
      </li>
      <li class="relative group" id="industriesDropdown">
        <a href="/industry-showcase" class="flex items-center gap-1 text-muted font-medium text-sm hover:text-dark transition-colors duration-200 cursor-pointer">
          Industries
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <!-- Dropdown panel -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-200" style="min-width: 230px;">
          <div class="bg-white rounded-2xl border border-border shadow-[0_8px_32px_rgba(0,0,0,0.1)] p-2 flex flex-col gap-0.5">
            <a href="/industry/professional-services" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#3b82f6;"></span>
              Professional Services
            </a>
            <a href="/industry/technology-it" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#8b5cf6;"></span>
              Technology & IT
            </a>
            <a href="/industry/construction-engineering" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#f97316;"></span>
              Construction & Engineering
            </a>
            <a href="/industry/marketing-creative" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#10b981;"></span>
              Marketing & Creative
            </a>
            <a href="/industry/finance-advisory" class="flex items-center gap-2.5 px-3.5 py-2.5 rounded-xl text-sm text-muted hover:text-dark hover:bg-light transition-colors duration-150">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#06b6d4;"></span>
              Finance & Advisory
            </a>
          </div>
        </div>
      </li>
      <li>
        <a href="/contact" class="inline-flex items-center justify-center px-5 py-2 text-sm font-semibold bg-primary text-white rounded-xl hover:bg-primary-hover hover:shadow-[0_4px_14px_rgba(38,39,94,0.3)] transition-all duration-200 cursor-pointer">
          Get Started
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile menu -->
  <div class="md:hidden overflow-hidden transition-all duration-300 max-h-0 mt-2" id="mobileMenu">
    <div class="bg-white rounded-2xl border border-border shadow-[0_8px_32px_rgba(0,0,0,0.1)] p-3">
      <ul class="flex flex-col gap-1">
        <li>
          <a href="/services" data-nav-link class="block py-3 px-4 text-center text-muted font-medium text-sm hover:text-dark hover:bg-light rounded-xl transition-all duration-200 cursor-pointer">Services</a>
          <div class="flex flex-col gap-0.5 pb-1">
            <a href="/services#website-redesign" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Website Redesign</a>
            <a href="/services#cinematic-heroes" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Cinematic Heroes</a>
            <a href="/services#built-in-analytics" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Built-in Analytics</a>
            <a href="/services#content-management" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Content Management</a>
            <a href="/services#seo-optimization" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">SEO Optimization</a>
            <a href="/services#maintenance-support" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Maintenance & Support</a>
          </div>
        </li>
        <li>
          <a href="/industry-showcase" data-nav-link class="w-full flex items-center justify-center gap-1 py-3 px-4 text-center text-muted font-medium text-sm hover:text-dark hover:bg-light rounded-xl transition-all duration-200 cursor-pointer" id="mobileIndustriesBtn">
            Industries
            <svg class="w-3.5 h-3.5 transition-transform duration-200" id="mobileIndustriesChevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </a>
          <div class="overflow-hidden transition-all duration-300 max-h-0" id="mobileIndustriesMenu">
            <div class="flex flex-col gap-0.5 pt-1 pb-1">
              <a href="/industry/professional-services" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Professional Services</a>
              <a href="/industry/technology-it" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Technology & IT</a>
              <a href="/industry/construction-engineering" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Construction & Engineering</a>
              <a href="/industry/marketing-creative" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Marketing & Creative</a>
              <a href="/industry/finance-advisory" data-nav-link class="block py-2 px-6 text-center text-xs text-muted hover:text-dark hover:bg-light rounded-xl transition-all duration-200">Finance & Advisory</a>
            </div>
          </div>
        </li>
        <li class="mt-1">
          <a href="/contact" class="block py-3 px-4 text-center text-sm font-semibold bg-primary text-white rounded-xl hover:bg-primary-hover transition-colors duration-200 cursor-pointer" data-nav-link>
            Get Started
          </a>
        </li>
      </ul>
    </div>
  </div>
</div>

<script>
  const navToggle = document.getElementById('navToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  const spans = navToggle?.querySelectorAll('span');

  let isOpen = false;

  navToggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (mobileMenu) {
      mobileMenu.style.maxHeight = isOpen ? mobileMenu.scrollHeight + 200 + 'px' : '0';
    }
    if (spans) {
      if (isOpen) {
        spans[0].style.transform = 'translateY(7px) rotate(45deg)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'translateY(-7px) rotate(-45deg)';
      } else {
        spans[0].style.transform = '';
        spans[1].style.opacity = '';
        spans[2].style.transform = '';
      }
    }
  });

  document.querySelectorAll('[data-nav-link]').forEach(link => {
    link.addEventListener('click', () => {
      isOpen = false;
      if (mobileMenu) mobileMenu.style.maxHeight = '0';
      if (spans) {
        spans[0].style.transform = '';
        spans[1].style.opacity = '';
        spans[2].style.transform = '';
      }
    });
  });
</script>
