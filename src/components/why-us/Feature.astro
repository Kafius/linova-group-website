---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="text-center">
  <div class="w-14 h-14 bg-light text-primary rounded-lg inline-flex items-center justify-center mb-4">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-dark font-semibold text-base mb-2">{title}</h3>
  <p class="text-muted text-sm">{description}</p>
</div>
