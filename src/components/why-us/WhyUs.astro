---
import Feature from './Feature.astro';

const features = [
  {
    title: 'Save Up to 70%',
    description: 'Get a world-class website at a fraction of what traditional agencies charge — no hidden fees, no surprises.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  },
  {
    title: 'Fully Responsive',
    description: 'Every site we build looks and works flawlessly on desktop, tablet, and mobile devices.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
  },
  {
    title: 'Fast Turnaround',
    description: 'Most projects are designed, built, and delivered in as little as 1-2 weeks.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  },
  {
    title: 'Blazing Fast Performance',
    description: 'Optimized for speed and search engines so your customers find you first.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
  },
  {
    title: 'Secure & Reliable',
    description: 'SSL, regular backups, and modern hosting ensure your site stays online and protected.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  },
  {
    title: 'Ongoing Support',
    description: "We don't disappear after launch. Get continued support and updates when you need them.",
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  },
];
---

<section class="py-24" id="why-us">
  <div class="max-w-[1140px] mx-auto px-6">
    <h2 class="text-3xl lg:text-4xl font-bold text-dark text-center mb-3 tracking-tight">Why Linova Group?</h2>
    <p class="text-center text-muted text-lg max-w-[600px] mx-auto mb-14">We deliver agency-quality websites without the agency overhead.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {features.map(feature => <Feature {...feature} />)}
    </div>
  </div>
</section>
