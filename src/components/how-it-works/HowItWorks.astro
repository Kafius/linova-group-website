---
import Step from './Step.astro';

const steps = [
  { number: 1, title: 'Tell Us Your Vision', description: "Share your goals, brand, and inspiration. We'll handle the rest." },
  { number: 2, title: 'We Design & Build', description: 'Our team crafts a custom, responsive website tailored to your business.' },
  { number: 3, title: 'Launch & Grow', description: 'Go live with confidence. We provide support so you can focus on your business.' },
];
---

<section class="py-28 bg-white" id="how-it-works">
  <div class="max-w-[1140px] mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Simple Process</span>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-dark tracking-tight mb-3">How It Works</h2>
      <p class="text-muted text-lg max-w-[480px] mx-auto">Three simple steps to your new website.</p>
    </div>

    <!-- Steps grid with connector line -->
    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Connector line (desktop only) -->
      <div class="absolute hidden md:block top-7 h-px" style="left: calc(100% / 6 + 28px); right: calc(100% / 6 + 28px); background: linear-gradient(90deg, transparent, #e5e7eb 20%, #e5e7eb 80%, transparent);"></div>

      {steps.map(step => <Step {...step} />)}
    </div>

  </div>
</section>
