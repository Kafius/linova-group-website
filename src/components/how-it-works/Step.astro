---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="text-center">
  <div class="w-12 h-12 bg-primary text-white rounded-full inline-flex items-center justify-center font-bold text-lg mb-5">
    {number}
  </div>
  <h3 class="text-dark font-semibold text-lg mb-2">{title}</h3>
  <p class="text-muted text-[0.95rem]">{description}</p>
</div>
