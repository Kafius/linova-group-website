---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="relative flex flex-col items-center text-center group cursor-default">
  <!-- Number circle -->
  <div class="relative z-10 w-14 h-14 bg-primary text-white rounded-2xl inline-flex items-center justify-center font-extrabold text-xl mb-6 shadow-[0_4px_20px_rgba(38,39,94,0.22)] group-hover:-translate-y-1 group-hover:shadow-[0_8px_28px_rgba(38,39,94,0.28)] transition-all duration-300">
    {number}
  </div>
  <h3 class="text-dark font-bold text-lg mb-2.5">{title}</h3>
  <p class="text-muted text-[0.95rem] leading-relaxed max-w-[240px] mx-auto">{description}</p>
</div>
