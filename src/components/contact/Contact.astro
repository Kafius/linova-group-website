---
---

<section class="py-24 bg-gradient-to-br from-dark to-[#1e293b] text-white" id="contact">
  <div class="max-w-[1140px] mx-auto px-6">
    <h2 class="text-3xl lg:text-4xl font-bold text-white text-center mb-3 tracking-tight">Ready to Get Started?</h2>
    <p class="text-center text-white/60 text-lg max-w-[600px] mx-auto mb-14">Tell us about your project and we'll get back to you within 24 hours with a free, no-obligation quote.</p>
    <form class="max-w-[640px] mx-auto flex flex-col gap-4" id="contactForm">
      <div class="flex flex-col sm:flex-row gap-4">
        <input
          type="text"
          name="name"
          placeholder="Your Name"
          required
          class="w-full px-4 py-3.5 rounded-lg border border-white/15 bg-white/[0.08] text-white font-sans text-[0.95rem] placeholder:text-white/40 focus:outline-none focus:border-primary focus:bg-white/[0.12] transition-all duration-200"
        />
        <input
          type="email"
          name="email"
          placeholder="Your Email"
          required
          class="w-full px-4 py-3.5 rounded-lg border border-white/15 bg-white/[0.08] text-white font-sans text-[0.95rem] placeholder:text-white/40 focus:outline-none focus:border-primary focus:bg-white/[0.12] transition-all duration-200"
        />
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <input
          type="text"
          name="business"
          placeholder="Business Name"
          class="w-full px-4 py-3.5 rounded-lg border border-white/15 bg-white/[0.08] text-white font-sans text-[0.95rem] placeholder:text-white/40 focus:outline-none focus:border-primary focus:bg-white/[0.12] transition-all duration-200"
        />
        <select
          name="industry"
          class="w-full px-4 py-3.5 rounded-lg border border-white/15 bg-white/[0.08] text-white/40 font-sans text-[0.95rem] focus:outline-none focus:border-primary focus:bg-white/[0.12] transition-all duration-200 [&>option]:text-dark [&>option]:bg-white"
        >
          <option value="" disabled selected>Select Your Industry</option>
          <option>Real Estate</option>
          <option>Restaurant & Hospitality</option>
          <option>Fitness & Wellness</option>
          <option>Legal & Professional Services</option>
          <option>E-Commerce & Retail</option>
          <option>Healthcare & Medical</option>
          <option>Other</option>
        </select>
      </div>
      <textarea
        name="message"
        rows="4"
        placeholder="Tell us about your project..."
        class="w-full px-4 py-3.5 rounded-lg border border-white/15 bg-white/[0.08] text-white font-sans text-[0.95rem] placeholder:text-white/40 focus:outline-none focus:border-primary focus:bg-white/[0.12] transition-all duration-200 resize-y"
      ></textarea>
      <button
        type="submit"
        class="self-center inline-flex items-center justify-center px-9 py-4 rounded-lg font-semibold text-[1.05rem] bg-primary text-white hover:bg-primary-hover hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(37,99,235,0.3)] transition-all duration-200"
      >
        Send Message
      </button>
    </form>
  </div>
</section>

<script>
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const data = Object.fromEntries(formData);
    console.log('Form submission:', data);
    alert("Thanks for reaching out! We'll get back to you within 24 hours.");
    (e.target as HTMLFormElement).reset();
  });
</script>
