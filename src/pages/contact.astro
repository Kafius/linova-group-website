---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar/Navbar.astro';
import Footer from '../components/footer/Footer.astro';
---

<Layout
  title="Contact — Linova Group"
  description="Get in touch with Linova Group. Tell us about your project and receive a free, no-obligation quote within 24 hours."
>
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-24 overflow-hidden text-white" style="background: radial-gradient(ellipse at 50% 50%, #2a2b6e 0%, #1a1b4b 45%, #16172f 100%);">
    <!-- Dot grid texture -->
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>

    <!-- Aurora mesh — all centered, expanding outward -->
    <!-- Core violet burst -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(109,40,217,0.22) 0%, transparent 70%); filter: blur(80px);"></div>
    <!-- Teal ring expanding outward -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, transparent 30%, rgba(20,184,166,0.12) 55%, transparent 75%); filter: blur(60px);"></div>
    <!-- Blue ring further out -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[900px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, transparent 40%, rgba(59,130,246,0.1) 65%, transparent 80%); filter: blur(70px);"></div>
    <!-- Soft indigo center glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[300px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(139,92,246,0.18) 0%, transparent 70%); filter: blur(50px);"></div>

    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
        Get In Touch
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.75rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Let's Build Something<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #93c5fd, #a5b4fc);">Great Together</span>
      </h1>
      <p class="text-white/55 text-lg max-w-[520px] mx-auto leading-relaxed font-medium mb-10">
        Tell us about your project and we'll get back to you within 24 hours with a free, no-obligation quote.
      </p>
      <!-- Spacer matching services hero CTA button row height -->
      <div aria-hidden="true" class="h-[52px]"></div>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="py-28 bg-white" id="contact">
    <div class="max-w-[1140px] mx-auto px-6">
      <div class="grid lg:grid-cols-5 gap-16 items-start">

        <!-- Left: form (wider) -->
        <div class="lg:col-span-3">

          <!-- Success message (shown by Formspree on submit) -->
          <div data-fs-success class="hidden flex-col items-center text-center gap-4 py-16 px-8 border border-green-200 bg-green-50 rounded-2xl">
            <div class="w-14 h-14 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <div class="text-dark font-bold text-xl mb-2">Message sent!</div>
              <p class="text-muted text-sm leading-relaxed max-w-sm">Thanks for reaching out. We'll review your project and get back to you within 24 hours.</p>
            </div>
          </div>

          <!-- Form-level error (shown by Formspree on failure) -->
          <div data-fs-error class="hidden mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm font-medium">
            Something went wrong. Please try again or email us directly.
          </div>

          <form id="contactForm" class="flex flex-col gap-4">
            <div class="flex flex-col sm:flex-row gap-4">
              <div class="flex flex-col gap-1.5 w-full">
                <label class="text-sm font-semibold text-dark">Your Name <span class="text-red-400">*</span></label>
                <input
                  type="text"
                  name="name"
                  placeholder="John Smith"
                  required
                  data-fs-field
                  class="w-full px-4 py-3.5 rounded-lg border border-border bg-white text-dark font-sans text-[0.95rem] placeholder:text-muted/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 aria-[invalid=true]:border-red-400"
                />
                <span data-fs-error="name" class="hidden text-xs text-red-500 font-medium"></span>
              </div>
              <div class="flex flex-col gap-1.5 w-full">
                <label class="text-sm font-semibold text-dark">Email Address <span class="text-red-400">*</span></label>
                <input
                  type="email"
                  name="email"
                  placeholder="john@example.com"
                  required
                  data-fs-field
                  class="w-full px-4 py-3.5 rounded-lg border border-border bg-white text-dark font-sans text-[0.95rem] placeholder:text-muted/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 aria-[invalid=true]:border-red-400"
                />
                <span data-fs-error="email" class="hidden text-xs text-red-500 font-medium"></span>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
              <div class="flex flex-col gap-1.5 w-full">
                <label class="text-sm font-semibold text-dark">Business Name</label>
                <input
                  type="text"
                  name="business"
                  placeholder="Acme Inc."
                  class="w-full px-4 py-3.5 rounded-lg border border-border bg-white text-dark font-sans text-[0.95rem] placeholder:text-muted/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200"
                />
              </div>
              <div class="flex flex-col gap-1.5 w-full">
                <label class="text-sm font-semibold text-dark">Industry</label>
                <select
                  name="industry"
                  class="w-full px-4 py-3.5 rounded-lg border border-border bg-white text-muted font-sans text-[0.95rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 [&>option]:text-dark"
                >
                  <option value="" disabled selected>Select Your Industry</option>
                  <option>Real Estate</option>
                  <option>Restaurant & Hospitality</option>
                  <option>Fitness & Wellness</option>
                  <option>Legal & Professional Services</option>
                  <option>E-Commerce & Retail</option>
                  <option>Healthcare & Medical</option>
                  <option>Construction & Trades</option>
                  <option>Other</option>
                </select>
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-semibold text-dark">What are you looking for?</label>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                {[
                  'New Website',
                  'Website Redesign',
                  'E-Commerce Store',
                  'SEO & Performance',
                  'Maintenance & Support',
                  'Not Sure Yet',
                ].map(option => (
                  <label class="flex items-center gap-2 border border-border rounded-lg px-3 py-2.5 cursor-pointer hover:border-primary hover:bg-primary/5 transition-all duration-150 has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                    <input type="checkbox" name="service" value={option} class="accent-primary w-3.5 h-3.5 flex-shrink-0" />
                    <span class="text-sm text-muted">{option}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-semibold text-dark">Tell us about your project</label>
              <textarea
                name="message"
                rows="5"
                placeholder="Describe your goals, timeline, any specific features you need..."
                class="w-full px-4 py-3.5 rounded-lg border border-border bg-white text-dark font-sans text-[0.95rem] placeholder:text-muted/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 resize-y"
              ></textarea>
            </div>

            <button
              type="submit"
              data-fs-submit-btn
              class="self-start inline-flex items-center gap-2 px-8 py-4 rounded-lg font-semibold text-[0.95rem] bg-primary text-white hover:bg-primary-hover hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(37,99,235,0.3)] transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0 disabled:shadow-none"
            >
              Send Message
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>

        <!-- Right: info cards -->
        <div class="lg:col-span-2 flex flex-col gap-6">

          <!-- Response time -->
          <div class="bg-light rounded-2xl p-6 border border-border">
            <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="text-dark font-bold text-base mb-1">Reply within 24 hours</div>
            <p class="text-muted text-sm leading-relaxed">We review every inquiry personally and get back to you fast — usually same day.</p>
          </div>

          <!-- Free quote -->
          <div class="bg-light rounded-2xl p-6 border border-border">
            <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <div class="text-dark font-bold text-base mb-1">Free, no-obligation quote</div>
            <p class="text-muted text-sm leading-relaxed">No pressure, no hidden fees. We'll send over a clear proposal tailored to your project.</p>
          </div>

          <!-- What happens next -->
          <div class="bg-light rounded-2xl p-6 border border-border">
            <div class="text-dark font-bold text-base mb-4">What happens next?</div>
            <ol class="flex flex-col gap-3">
              {[
                'We review your project details',
                'We send a custom quote & timeline',
                'Kick-off call to align on vision',
                'We get to work building your site',
              ].map((step, i) => (
                <li class="flex items-start gap-3">
                  <span class="w-5 h-5 rounded-full bg-primary text-white text-[10px] font-bold flex items-center justify-center flex-shrink-0 mt-0.5">{i + 1}</span>
                  <span class="text-sm text-muted">{step}</span>
                </li>
              ))}
            </ol>
          </div>

        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
  window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
  formspree('initForm', { formElement: '#contactForm', formId: 'xeepbppp' });
</script>
<script src="https://unpkg.com/@formspree/ajax@1" defer is:inline></script>
