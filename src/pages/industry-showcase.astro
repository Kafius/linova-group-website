<div style="background:rgba(255,255,255,0.04);padding:12px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.08);">
<div><div style="color:${c.accent};font-size:13px;font-weight:300;letter-spacing:4px;text-transform:uppercase;">${c.biz}</div><div style="color:rgba(255,255,255,0.3);font-size:8px;letter-spacing:2px;text-transform:uppercase;">${c.sub2}</div></div>
<div style="display:flex;gap:20px;align-items:center;"><span style="color:rgba(255,255,255,0.45);font-size:10px;">Portfolio</span><span style="color:rgba(255,255,255,0.45);font-size:10px;">Services</span><span style="color:rgba(255,255,255,0.45);font-size:10px;">About</span><div style="border:1px solid ${c.accent};color:${c.accent};font-size:10px;font-weight:600;padding:7px 16px;border-radius:4px;">${c.cta2}</div></div>
</div>
