const TMPLS = { dark: tmplDark, luxury: tmplLuxury, professional: tmplProfessional, shop: tmplShop, creative: tmplCreative, wellness: tmplWellness };

// ─── RENDER CARD ─────────────────────────────────────────────────────────────
function renderCard(ind) {
  const c = ind.cfg;
  const isDark = ['dark','luxury','creative'].includes(ind.template);
  const previewBg = c.bg && !c.bg.includes('gradient') ? c.bg : (isDark ? '#0d1117' : '#f8fafc');
  const accentColor = c.accent;
  const textColor = isDark ? '#ffffff' : (c.dark || '#0f172a');
  const mutedColor = isDark ? 'rgba(255,255,255,0.45)' : '#64748b';
  const bizName = c.biz || ind.label.toUpperCase();

  return `<div class="ind-card group cursor-pointer rounded-xl overflow-hidden border border-[#e2e8f0] hover:border-[${accentColor}] hover:shadow-lg transition-all duration-200" data-id="${ind.id}" data-category="${ind.category}" data-label="${ind.label.toLowerCase()}">
  <div style="background:${previewBg};height:140px;padding:14px 16px;position:relative;overflow:hidden;">
    <div style="position:absolute;bottom:-20px;right:-20px;width:100px;height:100px;background:radial-gradient(circle,${accentColor} 0%,transparent 70%);opacity:0.25;pointer-events:none;"></div>
    <div style="position:absolute;bottom:0;left:0;right:0;height:2px;background:${accentColor};opacity:0.7;"></div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div style="display:flex;align-items:center;gap:5px;overflow:hidden;">
        <div style="width:14px;height:14px;background:${accentColor};border-radius:3px;flex-shrink:0;"></div>
        <span style="color:${textColor};font-size:8px;font-weight:800;letter-spacing:0.5px;opacity:0.9;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100px;">${bizName}</span>
      </div>
      <div style="background:${accentColor};color:white;font-size:7px;font-weight:700;padding:3px 8px;border-radius:3px;flex-shrink:0;">View</div>
    </div>
    <div style="color:${textColor};font-size:14px;font-weight:900;line-height:1.2;margin-bottom:5px;">${(c.hl||ind.label).split('\\n')[0]}</div>
    <div style="color:${mutedColor};font-size:9px;line-height:1.4;">${ind.tagline}</div>
  </div>
  <div style="padding:11px 14px;background:white;display:flex;align-items:center;justify-content:space-between;">
    <div>
      <div style="font-weight:700;font-size:13px;color:#0f172a;">${ind.label}</div>
      <div style="font-size:10px;color:#64748b;margin-top:1px;">${CAT_LABELS[ind.category]||''}</div>
    </div>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </div>
</div>`;
}

// ─── RENDER PANEL ────────────────────────────────────────────────────────────
function renderPanel(ind) {
  const copy = `
    <p style="font-size:11px;font-weight:700;color:#2563eb;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;">${CAT_LABELS[ind.category]}</p>
    <h2 style="font-size:26px;font-weight:800;color:#0f172a;line-height:1.2;margin-bottom:12px;">${ind.label} Websites That Convert</h2>
    <p style="color:#64748b;font-size:15px;line-height:1.7;margin-bottom:24px;">${ind.desc}</p>
    <ul style="display:flex;flex-direction:column;gap:12px;margin-bottom:28px;">
      ${ind.features.map(f=>`<li style="display:flex;align-items:flex-start;gap:10px;"><div style="width:18px;height:18px;border-radius:50%;background:#eff6ff;color:#2563eb;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span style="font-size:14px;color:#0f172a;">${f}</span></li>`).join('')}
    </ul>
    <a href="/contact" style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;background:#2563eb;color:white;border-radius:8px;font-weight:600;font-size:14px;text-decoration:none;">${ind.cta} <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>`;

  const mockupHtml = TMPLS[ind.template]?.(ind.cfg) || '';
  const mockup = `
    <div style="border-radius:16px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.15);border:1px solid #e2e8f0;">
      <div style="background:#f1f3f4;border-bottom:1px solid #e2e8f0;padding:10px 16px;display:flex;align-items:center;gap:8px;">
        <span style="width:10px;height:10px;border-radius:50%;background:#f87171;display:inline-block;"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#fbbf24;display:inline-block;"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#4ade80;display:inline-block;"></span>
        <div style="flex:1;background:white;border-radius:4px;padding:4px 10px;font-size:10px;color:#94a3b8;margin-left:4px;display:flex;align-items:center;gap:5px;">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          ${ind.cfg.domain || ind.id + '.com'}
        </div>
      </div>
      <div class="mockup-wrap" style="overflow:hidden;"><div class="mockup-inner" style="width:780px;transform-origin:top left;">${mockupHtml}</div></div>
    </div>`;

  return { copy, mockup };
}

// ─── FILTER & RENDER GRID ─────────────────────────────────────────────────────
let activeCat = 'all';
let searchQuery = '';
let activeId = null;

function getFiltered() {
  return INDUSTRIES.filter(ind => {
    const catOk = activeCat === 'all' || ind.category === activeCat;
    const searchOk = !searchQuery || ind.label.toLowerCase().includes(searchQuery) || ind.category.toLowerCase().includes(searchQuery) || (CAT_LABELS[ind.category]||'').toLowerCase().includes(searchQuery);
    return catOk && searchOk;
  });
}

function renderGrid() {
  const filtered = getFiltered();
  const grid = document.getElementById('industry-grid');
  const noResults = document.getElementById('no-results');
  const count = document.getElementById('ind-count');

  if (!filtered.length) {
    grid.innerHTML = '';
    noResults.classList.remove('hidden');
    noResults.classList.add('flex');
    count.textContent = '0 industries';
    closePanel();
    return;
  }

  noResults.classList.add('hidden');
  noResults.classList.remove('flex');
  count.textContent = `${filtered.length} ${filtered.length === 1 ? 'industry' : 'industries'}`;
  grid.innerHTML = filtered.map(renderCard).join('');

  grid.querySelectorAll('.ind-card').forEach(card => {
    card.addEventListener('click', () => openPanel(card.dataset.id));
  });

  // If active panel industry is no longer in filtered, close it
  if (activeId && !filtered.find(i => i.id === activeId)) closePanel();
}

function openPanel(id) {
  const ind = INDUSTRIES.find(i => i.id === id);
  if (!ind) return;
  activeId = id;

  // Highlight active card
  document.querySelectorAll('.ind-card').forEach(c => {
    c.style.outline = c.dataset.id === id ? '2px solid #2563eb' : '';
    c.style.outlineOffset = c.dataset.id === id ? '2px' : '';
  });

  const panel = document.getElementById('industry-panel');
  const copyEl = document.getElementById('panel-copy');
  const mockupEl = document.getElementById('panel-mockup');
  const { copy, mockup } = renderPanel(ind);

  copyEl.innerHTML = copy;
  mockupEl.innerHTML = mockup;
  panel.classList.remove('hidden');
  panel.style.opacity = '0';
  panel.style.transition = 'opacity 0.25s ease';
  requestAnimationFrame(() => { panel.style.opacity = '1'; });

  // Scale mockup
  requestAnimationFrame(() => scaleMockup(panel));

  // Scroll panel into view
  setTimeout(() => panel.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

function closePanel() {
  activeId = null;
  const panel = document.getElementById('industry-panel');
  panel.classList.add('hidden');
  document.querySelectorAll('.ind-card').forEach(c => { c.style.outline = ''; c.style.outlineOffset = ''; });
}

function scaleMockup(container) {
  const wrap = container.querySelector('.mockup-wrap');
  const inner = container.querySelector('.mockup-inner');
  if (!wrap || !inner) return;
  const scale = wrap.offsetWidth / 780;
  inner.style.transform = `scale(${scale})`;
  wrap.style.height = Math.round(500 * scale) + 'px';
}

// ─── EVENTS ───────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  renderGrid();

  // Category filter
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat;
      document.querySelectorAll('.cat-btn').forEach(b => {
        b.classList.toggle('bg-primary', b.dataset.cat === activeCat);
        b.classList.toggle('text-white', b.dataset.cat === activeCat);
        b.classList.toggle('bg-light', b.dataset.cat !== activeCat);
        b.classList.toggle('text-muted', b.dataset.cat !== activeCat);
      });
      closePanel();
      renderGrid();
    });
  });

  // Search
  document.getElementById('industry-search').addEventListener('input', e => {
    searchQuery = e.target.value.toLowerCase().trim();
    closePanel();
    renderGrid();
  });

  // Clear search
  document.getElementById('clear-search')?.addEventListener('click', () => {
    searchQuery = '';
    document.getElementById('industry-search').value = '';
    closePanel();
    renderGrid();
  });

  // Back button
  document.getElementById('panel-back').addEventListener('click', () => {
    closePanel();
    document.getElementById('showcase-bar').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Resize observer for mockup scaling
  const ro = new ResizeObserver(() => {
    const panel = document.getElementById('industry-panel');
    if (!panel.classList.contains('hidden')) scaleMockup(panel);
  });
  const wrap = document.querySelector('.mockup-wrap');
  if (wrap) ro.observe(wrap);
  else ro.observe(document.getElementById('industry-panel'));
});
</script>
