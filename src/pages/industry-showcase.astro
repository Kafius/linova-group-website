function tmplDark(c) {
  const chips = c.chips.map(s=>`<div style="background:${c.nav};border:1px solid ${c.border};color:${c.muted};font-size:10px;padding:6px 14px;border-radius:4px;white-space:nowrap;">${s}</div>`).join('');
  const stats = c.stats.map(([v,l])=>`<div style="text-align:center;"><div style="color:${c.accent};font-size:20px;font-weight:900;line-height:1;">${v}</div><div style="color:${c.muted};font-size:8px;text-transform:uppercase;letter-spacing:1px;margin-top:3px;">${l}</div></div>`).join('');
  return `<div style="background:${c.bg};width:780px;height:500px;font-family:system-ui,sans-serif;overflow:hidden;">
<div style="background:${c.nav};padding:12px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid ${c.border};">
<div style="display:flex;align-items:center;gap:8px;"><div style="width:26px;height:26px;background:${c.accent};border-radius:5px;flex-shrink:0;"></div><span style="color:#fff;font-weight:900;font-size:12px;letter-spacing:1px;">${c.biz}</span></div>
<div style="display:flex;gap:16px;align-items:center;"><span style="color:${c.muted};font-size:10px;">Services</span><span style="color:${c.muted};font-size:10px;">Portfolio</span><span style="color:${c.muted};font-size:10px;">About</span><div style="background:${c.accent};color:#fff;font-size:10px;font-weight:700;padding:7px 16px;border-radius:5px;">${c.chips[0] ? 'Get a Quote' : 'Contact'}</div></div>
</div>
<div style="padding:32px;position:relative;overflow:hidden;background:linear-gradient(145deg,${c.bg},${c.nav});">
<div style="position:absolute;top:-40px;right:-20px;width:220px;height:220px;background:radial-gradient(circle,${c.dim} 0%,transparent 70%);border-radius:50%;pointer-events:none;"></div>
<div style="color:${c.accent};font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;display:inline-block;background:${c.dim};padding:4px 12px;border-radius:20px;">${c.biz}</div>
<div style="color:#fff;font-size:30px;font-weight:900;line-height:1.1;margin-bottom:12px;">${c.hl.replace(/\n/g,'<br/>')}</div>
<div style="color:${c.muted};font-size:11px;max-width:340px;line-height:1.7;margin-bottom:20px;">${c.sub}</div>
<div style="display:flex;gap:10px;margin-bottom:24px;">
<div style="background:${c.accent};color:#fff;font-size:11px;font-weight:700;padding:10px 22px;border-radius:6px;">Get a Quote</div>
<div style="color:${c.muted};font-size:11px;padding:10px 22px;border-radius:6px;border:1px solid ${c.border};">Learn More</div>
</div>
<div style="display:flex;gap:28px;padding-top:20px;border-top:1px solid ${c.border};">${stats}</div>
</div>
<div style="background:${c.nav};border-top:1px solid ${c.border};padding:12px 32px;display:flex;gap:10px;flex-wrap:wrap;overflow:hidden;">${chips}</div>
</div>`;
}

function tmplLuxury(c) {
  const cats = c.cats.map((l,i)=>`<div style="font-size:10px;font-weight:600;padding:6px 14px;border-radius:20px;cursor:pointer;${i===0?`background:${c.accent};color:${c.bg};`:`color:${c.muted};border:1px solid ${c.border};`}">${l}</div>`).join('');
  const hl = c.hl.split('\n');
  const lastWord = c.accentWord;
  const hlHtml = hl.map((line,i) => {
    if (i === hl.length-1 && lastWord) {
      return line.replace(lastWord, `<span style="color:${c.accent};font-weight:800;font-style:normal;">${lastWord}</span>`);
    }
    return line;
  }).join('<br/>');
  return `<div style="background:${c.bg};width:780px;height:500px;font-family:system-ui,sans-serif;overflow:hidden;">
<div style="background:${c.nav};padding:12px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid ${c.border};">
<div style="text-align:center;"><div style="color:${c.accent};font-size:14px;font-weight:900;letter-spacing:4px;text-transform:uppercase;line-height:1;">${c.biz}</div><div style="color:${c.accent};opacity:0.55;font-size:7.5px;letter-spacing:3px;text-transform:uppercase;margin-top:1px;">${c.sub2}</div></div>
<div style="display:flex;gap:22px;align-items:center;"><span style="color:${c.muted};font-size:10px;">Menu</span><span style="color:${c.muted};font-size:10px;">Events</span><span style="color:${c.muted};font-size:10px;">About</span><div style="border:1px solid ${c.accent};color:${c.accent};font-size:10px;font-weight:700;padding:7px 16px;border-radius:4px;letter-spacing:1px;">${c.cta2.toUpperCase()}</div></div>
</div>
<div style="background:linear-gradient(170deg,${c.bg} 0%,${c.bg} 100%);padding:30px 32px 22px;position:relative;overflow:hidden;">
<div style="position:absolute;top:0;right:0;width:260px;height:200px;background:radial-gradient(circle at 70% 30%,${c.dim} 0%,transparent 70%);pointer-events:none;"></div>
<div style="display:flex;align-items:flex-start;justify-content:space-between;">
<div style="flex:1;">
<div style="color:${c.accent};opacity:0.6;font-size:9px;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;">${c.sub2}</div>
<div style="color:#fff;font-size:30px;font-weight:300;line-height:1.2;margin-bottom:8px;font-style:italic;">${hlHtml}</div>
<div style="color:${c.muted};font-size:11px;max-width:280px;line-height:1.7;margin-bottom:20px;">${c.body}</div>
<div style="display:flex;gap:10px;">
<div style="background:${c.accent};color:${c.bg};font-size:11px;font-weight:800;padding:10px 22px;border-radius:4px;">${c.cta2}</div>
<div style="color:${c.muted};font-size:11px;padding:10px 22px;border-radius:4px;border:1px solid ${c.border};">View Menu</div>
</div>
</div>
<div style="background:rgba(255,255,255,0.04);border:1px solid ${c.accent};opacity:0.7;border-radius:10px;padding:14px 18px;text-align:center;flex-shrink:0;margin-left:16px;min-width:140px;">
<div style="color:${c.accent};font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:10px;">Hours</div>
${c.hours.map(h=>`<div style="color:rgba(255,255,255,0.7);font-size:9px;line-height:1.9;">${h}</div>`).join('<div style="border-top:1px solid rgba(255,255,255,0.08);margin:6px 0;"></div>')}
</div>
</div>
</div>
<div style="background:rgba(255,255,255,0.03);border-top:1px solid ${c.border};padding:12px 32px;display:flex;gap:8px;align-items:center;">${cats}</div>
</div>`;
}

