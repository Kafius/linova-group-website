<div style="display:flex;gap:20px;align-items:center;"><span style="color:${c.muted};font-size:10px;">Schedule</span><span style="color:${c.muted};font-size:10px;">Instructors</span><span style="color:${c.muted};font-size:10px;">Pricing</span><div style="background:${c.accent};color:white;font-size:10px;font-weight:700;padding:7px 16px;border-radius:5px;">${c.cta1}</div></div>
</div>
<div style="background:linear-gradient(160deg,${c.aLight} 0%,${c.bg} 100%);padding:28px 32px 20px;position:relative;overflow:hidden;">
<div style="position:absolute;right:-10px;top:-10px;width:180px;height:180px;background:radial-gradient(circle,${c.aBorder} 0%,transparent 70%);pointer-events:none;"></div>
<div style="display:inline-flex;align-items:center;gap:6px;background:${c.badgeColor};color:${c.badgeText};font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;padding:4px 12px;border-radius:20px;margin-bottom:14px;">${c.badge}</div>
