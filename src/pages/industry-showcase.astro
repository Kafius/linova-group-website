---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar/Navbar.astro';
import Footer from '../components/footer/Footer.astro';

const categories = [
  { id: 'all',          label: 'All Industries' },
  { id: 'trades',       label: 'Trades & Construction' },
  { id: 'food',         label: 'Food & Hospitality' },
  { id: 'health',       label: 'Health & Wellness' },
  { id: 'professional', label: 'Professional Services' },
  { id: 'retail',       label: 'Retail & Commerce' },
  { id: 'creative',     label: 'Creative & Lifestyle' },
];
---

<Layout title="Industry Showcase — Linova Group" description="Browse website mockups for 25+ industries. See how Linova Group designs sites tailored to construction, restaurants, legal, medical, e-commerce, and more.">
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden text-white" style="background: linear-gradient(135deg, #16172f 0%, #26275E 50%, #1e1f4a 100%);">
    <div class="absolute inset-0 opacity-[0.045]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-0 right-1/4 w-[520px] h-[320px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(96,165,250,0.07) 0%, transparent 70%); filter: blur(70px);"></div>
    <div class="absolute bottom-0 left-1/3 w-[400px] h-[280px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(79,70,229,0.1) 0%, transparent 70%); filter: blur(60px);"></div>
    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
        Industry Showcase
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.75rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        A Website Built<br class="hidden sm:block" /> for Your Industry
      </h1>
      <p class="text-white/55 text-lg max-w-[560px] mx-auto leading-relaxed font-medium">
        Browse real design mockups for 25 industries. Every site is tailored to how your customers search, decide, and convert.
      </p>
    </div>
  </section>

  <!-- Sticky search + filter bar -->
  <div class="sticky top-[84px] z-40 bg-white border-b border-border shadow-sm" id="showcase-bar">
    <div class="max-w-[1140px] mx-auto px-6 py-3 flex flex-col sm:flex-row gap-3 items-start sm:items-center">
      <!-- Search -->
      <div class="relative w-full sm:w-64 flex-shrink-0">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-muted" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="text"
          id="industry-search"
          placeholder="Search industries…"
          autocomplete="off"
          class="w-full pl-9 pr-4 py-2.5 rounded-lg border border-border bg-light text-sm text-dark placeholder:text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200"
        />
      </div>
      <!-- Category pills -->
      <div class="flex items-center gap-1.5 overflow-x-auto scrollbar-none flex-1">
        {categories.map((cat, i) => (
          <button
            data-cat={cat.id}
            class={`cat-btn flex-shrink-0 px-3.5 py-1.5 rounded-full text-xs font-semibold whitespace-nowrap transition-all duration-200 cursor-pointer ${i === 0 ? 'bg-primary text-white' : 'bg-light text-muted hover:text-dark hover:bg-[#e8edf2]'}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
      <!-- Count -->
      <span class="text-xs text-muted whitespace-nowrap flex-shrink-0" id="ind-count">25 industries</span>
    </div>
  </div>

  <!-- Grid -->
  <section class="py-12 bg-[#f8fafc] min-h-[400px]">
    <div class="max-w-[1140px] mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4" id="industry-grid">
        <!-- Populated by JS -->
      </div>
      <div class="hidden flex-col items-center justify-center py-20 text-center" id="no-results">
        <div class="w-14 h-14 rounded-full bg-light flex items-center justify-center mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <p class="text-dark font-semibold mb-1">No results found</p>
        <p class="text-muted text-sm">Try a different search or <button class="text-primary underline" id="clear-search">clear the filter</button></p>
      </div>
    </div>
  </section>

  <!-- Expanded panel -->
  <div class="hidden border-t-[3px] border-primary bg-white" id="industry-panel">
    <div class="max-w-[1140px] mx-auto px-6 py-12">
      <button id="panel-back" class="inline-flex items-center gap-2 text-sm text-muted hover:text-dark transition-colors mb-10 cursor-pointer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to showcase
      </button>
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <div class="lg:col-span-2 order-2 lg:order-1" id="panel-copy"></div>
        <div class="lg:col-span-3 order-1 lg:order-2" id="panel-mockup"></div>
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="relative py-24 overflow-hidden text-white text-center" style="background: linear-gradient(135deg, #16172f 0%, #26275E 60%, #1e1f4a 100%);">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="relative max-w-[640px] mx-auto px-6">
      <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-blue-300/70 mb-4">Any Industry</span>
      <h2 class="text-3xl lg:text-4xl font-extrabold mb-4 tracking-tight">Don't See Your Industry?</h2>
      <p class="text-white/55 text-lg mb-8 leading-relaxed">We design for any business. Tell us about yours and we'll show you what's possible.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold bg-white text-primary hover:bg-white/90 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(255,255,255,0.15)] transition-all duration-200 cursor-pointer">
        Get a Free Quote
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

