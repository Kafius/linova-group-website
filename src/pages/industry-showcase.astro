---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar/Navbar.astro';
import Footer from '../components/footer/Footer.astro';

const cards = [
  {
    id: 'professional-services',
    label: 'Professional Services',
    tagline: 'Law firms, consultancies & accounting practices that win clients on credibility.',
    gradient: 'linear-gradient(160deg, #0a1020 0%, #1e3a8a 55%, #2563eb 100%)',
    accent: '#3b82f6',
    video: '',
  },
  {
    id: 'technology-it',
    label: 'Technology & IT',
    tagline: 'SaaS platforms, managed service providers & cybersecurity firms.',
    gradient: 'linear-gradient(160deg, #10071e 0%, #4c1d95 55%, #7c3aed 100%)',
    accent: '#8b5cf6',
    video: '',
  },
  {
    id: 'construction-engineering',
    label: 'Construction & Engineering',
    tagline: 'Commercial builders, architects & facilities management companies.',
    gradient: 'linear-gradient(160deg, #140a04 0%, #7c2d12 55%, #ea580c 100%)',
    accent: '#f97316',
    video: '',
  },
  {
    id: 'marketing-creative',
    label: 'Marketing & Creative',
    tagline: 'Digital agencies, branding studios & video production companies.',
    gradient: 'linear-gradient(160deg, #071410 0%, #064e3b 55%, #059669 100%)',
    accent: '#10b981',
    video: '',
  },
  {
    id: 'finance-advisory',
    label: 'Finance & Advisory',
    tagline: 'Business lenders, wealth managers & commercial insurance brokers.',
    gradient: 'linear-gradient(160deg, #04101a 0%, #164e63 55%, #0891b2 100%)',
    accent: '#06b6d4',
    video: '',
  },
];
---

<Layout title="Industry Showcase — Linova Group" description="See how Linova Group designs high-converting websites for B2B businesses across every major industry.">
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-24 overflow-hidden text-white" style="background: radial-gradient(ellipse at 50% 50%, #2a2b6e 0%, #1a1b4b 45%, #16172f 100%);">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(109,40,217,0.22) 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, transparent 30%, rgba(20,184,166,0.12) 55%, transparent 75%); filter: blur(60px);"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[900px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, transparent 40%, rgba(59,130,246,0.1) 65%, transparent 80%); filter: blur(70px);"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[300px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(139,92,246,0.18) 0%, transparent 70%); filter: blur(50px);"></div>

    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
        Industry Showcase
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.75rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Built for<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #93c5fd, #a5b4fc);">Your Industry</span>
      </h1>
      <p class="text-white/55 text-lg max-w-[520px] mx-auto leading-relaxed font-medium mb-10">
        We build for B2B. Every site is designed around how your clients search, evaluate, and decide who to trust.
      </p>
      <div aria-hidden="true" class="h-[52px]"></div>
    </div>
  </section>

  <!-- 5-Card B2B Showcase -->
  <section class="py-16 bg-[#07080f]">
    <div class="max-w-[1400px] mx-auto px-6">

      <!-- Section label -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-blue-400/60 mb-1">B2B Industries</p>
          <h2 class="text-white text-2xl font-bold">Browse by Sector</h2>
        </div>
        <p class="text-white/30 text-sm hidden sm:block">Hover to explore</p>
      </div>

      <!-- Cards row -->
      <div class="flex gap-3 h-[560px] sm:h-[600px]" id="cards-row">
        {cards.map((card, idx) => (
          <a
            href={`/industry/${card.id}`}
            class="showcase-card relative rounded-2xl overflow-hidden cursor-pointer block"
            style={`flex: 1; min-width: 0; transition: flex 0.5s cubic-bezier(0.4,0,0.2,1);`}
            data-accent={card.accent}
          >
            <!-- Gradient bg (visible as poster when no video) -->
            <div class="absolute inset-0" style={`background: ${card.gradient};`}></div>

            <!-- Noise texture overlay -->
            <div class="absolute inset-0 opacity-[0.035]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox%3D%220 0 200 200%22 xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cfilter id%3D%22n%22%3E%3CfeTurbulence type%3D%22fractalNoise%22 baseFrequency%3D%220.9%22 numOctaves%3D%224%22 stitchTiles%3D%22stitch%22%2F%3E%3C%2Ffilter%3E%3Crect width%3D%22100%25%22 height%3D%22100%25%22 filter%3D%22url(%23n)%22%2F%3E%3C%2Fsvg%3E'); background-size: 180px 180px;"></div>

            <!-- Video element — set src when ready, plays on hover -->
            <video
              class="card-video absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
              muted
              playsinline
              loop
              preload="none"
              data-src={card.video}
            ></video>

            <!-- Bottom shadow gradient -->
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.25) 45%, rgba(0,0,0,0.05) 100%);"></div>

            <!-- Accent glow (appears on hover) -->
            <div
              class="card-glow absolute inset-0 opacity-0 transition-opacity duration-500 pointer-events-none"
              style={`background: radial-gradient(ellipse at 50% 120%, ${card.accent}55 0%, transparent 65%);`}
            ></div>

            <!-- Accent top edge line -->
            <div
              class="absolute top-0 left-0 right-0 h-[2px] opacity-0 card-edge transition-opacity duration-300"
              style={`background: ${card.accent};`}
            ></div>

            <!-- Large index number (background) -->
            <div class="absolute top-4 left-5 select-none pointer-events-none">
              <span class="font-black text-[72px] leading-none" style="color: rgba(255,255,255,0.06);">
                {String(idx + 1).padStart(2, '0')}
              </span>
            </div>

            <!-- Content -->
            <div class="absolute inset-0 flex flex-col justify-end p-5 sm:p-6">
              <!-- Badge -->
              <div class="mb-3">
                <span
                  class="inline-block text-[9px] font-bold uppercase tracking-[0.18em] px-2.5 py-1 rounded-full"
                  style={`background: ${card.accent}20; color: ${card.accent}; border: 1px solid ${card.accent}35;`}
                >
                  B2B
                </span>
              </div>

              <!-- Label -->
              <h3 class="text-white font-bold text-lg sm:text-xl leading-snug mb-1.5">{card.label}</h3>

              <!-- Tagline — revealed on hover -->
              <p class="card-tagline text-white/50 text-sm leading-relaxed opacity-0 translate-y-2 transition-all duration-300"
                 style="max-height: 0; overflow: hidden;">
                {card.tagline}
              </p>

              <!-- CTA arrow — revealed on hover -->
              <div class="card-cta mt-0 opacity-0 translate-y-2 transition-all duration-300 delay-75"
                   style="max-height: 0; overflow: hidden;">
                <span class="inline-flex items-center gap-1.5 text-sm font-semibold" style={`color: ${card.accent};`}>
                  Learn more
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="relative py-24 overflow-hidden text-white text-center" style="background: linear-gradient(135deg, #16172f 0%, #26275E 60%, #1e1f4a 100%);">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="relative max-w-[640px] mx-auto px-6">
      <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-blue-300/70 mb-4">Any Industry</span>
      <h2 class="text-3xl lg:text-4xl font-extrabold mb-4 tracking-tight">Don't See Your Industry?</h2>
      <p class="text-white/55 text-lg mb-8 leading-relaxed">We design for any business. Tell us about yours and we'll show you what's possible.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold bg-white text-primary hover:bg-white/90 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(255,255,255,0.15)] transition-all duration-200 cursor-pointer">
        Get a Free Quote
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const row = document.getElementById('cards-row');
  const cards = Array.from(row.querySelectorAll('.showcase-card'));

  cards.forEach(card => {
    const video = card.querySelector('.card-video');
    const glow = card.querySelector('.card-glow');
    const edge = card.querySelector('.card-edge');
    const tagline = card.querySelector('.card-tagline');
    const cta = card.querySelector('.card-cta');

    // Lazy-load video src when ready
    const src = video.dataset.src;
    if (src) video.src = src;

    card.addEventListener('mouseenter', () => {
      // Accordion: expand this card, compress others
      cards.forEach(c => {
        c.style.flex = c === card ? '2.5' : '0.65';
      });

      // Show video if available
      if (src) {
        video.currentTime = 0;
        video.play().catch(() => {});
        video.style.opacity = '1';
      }

      // Reveal overlays + content
      glow.style.opacity = '1';
      edge.style.opacity = '1';

      tagline.style.opacity = '1';
      tagline.style.transform = 'translateY(0)';
      tagline.style.maxHeight = '80px';

      cta.style.opacity = '1';
      cta.style.transform = 'translateY(0)';
      cta.style.maxHeight = '40px';
      cta.style.marginTop = '12px';
    });

    card.addEventListener('mouseleave', () => {
      // Reset all cards to equal flex
      cards.forEach(c => { c.style.flex = '1'; });

      // Hide video
      if (src) {
        video.pause();
        video.style.opacity = '0';
      }

      glow.style.opacity = '0';
      edge.style.opacity = '0';

      tagline.style.opacity = '0';
      tagline.style.transform = 'translateY(8px)';
      tagline.style.maxHeight = '0';

      cta.style.opacity = '0';
      cta.style.transform = 'translateY(8px)';
      cta.style.maxHeight = '0';
      cta.style.marginTop = '0';
    });
  });
});
</script>
