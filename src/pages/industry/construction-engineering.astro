---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar/Navbar.astro';
import Footer from '../../components/footer/Footer.astro';
import MockupViewToggle from '../../components/industry/MockupViewToggle.astro';
---

<Layout title="Construction & Engineering — Linova Group" description="Web design for commercial builders, architects & facilities management companies.">
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden text-white" style="background: radial-gradient(ellipse at 50% 50%, #7c2d12 0%, #431407 45%, #140a04 100%);">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(234,88,12,0.2) 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-orange-400 inline-block"></span>
        Construction & Engineering
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Websites Built as Strong<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #fb923c, #fbbf24);">as Your Projects</span>
      </h1>
      <p class="text-white/55 text-lg max-w-[540px] mx-auto leading-relaxed font-medium">
        Commercial builders, architects, and contractors win jobs on reputation. We build the digital presence that showcases your work and earns the trust of developers and project managers.
      </p>
    </div>
  </section>

  <!-- Interactive Showcase -->
  <section class="py-20 bg-[#07080f]">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-orange-400/60 mb-2">Live Example</p>
        <h2 class="text-white text-2xl sm:text-3xl font-bold mb-3">See What We'd Build for a Builder</h2>
        <p class="text-white/40 text-sm">Switch pages, hover elements, and explore the full design.</p>
      </div>

      <MockupViewToggle />

      <div class="mockup-switcher" data-view="desktop">
      <!-- Desktop browser mockup -->
      <div class="mockup-desktop rounded-2xl overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.6)] border border-white/10">
        <div class="flex items-center gap-3 px-5 py-3" style="background:#1a1208; border-bottom:1px solid rgba(255,255,255,0.08);">
          <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
          <div class="flex-1 flex items-center gap-2 rounded-full px-4 py-1.5 ml-2 text-xs" style="background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.4); max-width:300px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            apexbuilt.com.au
          </div>
        </div>

        <div style="height:620px;overflow-y:auto;overflow-x:hidden;" id="const-viewport">

          <!-- PAGE 0: HOME -->
          <div class="const-page" data-page="0">
            <nav style="background:#0f0a06;border-bottom:1px solid rgba(234,88,12,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="const-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#ea580c,#b45309);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <span style="color:#fef3e2;font-size:15px;font-weight:800;letter-spacing:-0.01em;">APEX BUILT</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Projects',g:'1'},{n:'Services',g:'2'}].map(item=>(
                  <span style="color:rgba(254,243,226,0.45);font-size:13px;cursor:pointer;" class="const-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#ea580c,#b45309);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;" class="const-nav" data-goto="3">Request a Quote</button>
              </div>
            </nav>

            <!-- Hero (Video-First) -->
            <div style="position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;">
              <!-- Background video -->
              <video autoplay muted loop playsinline src="/videos/construction-engineering.mp4" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"></video>
              <!-- Dark overlay for text readability -->
              <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(10,7,3,0.93) 0%,rgba(15,10,6,0.78) 45%,rgba(15,10,6,0.5) 100%);pointer-events:none;"></div>
              <!-- Accent top line -->
              <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#ea580c,transparent);"></div>

              <div style="position:relative;padding:96px 48px 80px;max-width:680px;">
                <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(234,88,12,0.15);border:1px solid rgba(234,88,12,0.3);padding:6px 14px;border-radius:20px;margin-bottom:28px;backdrop-filter:blur(8px);">
                  <span style="width:6px;height:6px;background:#ea580c;border-radius:50%;"></span>
                  <span style="color:#fb923c;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;">Commercial Construction · Victoria</span>
                </div>
                <h1 style="font-size:52px;font-weight:900;color:#ffffff;line-height:1.05;margin:0 0 20px;letter-spacing:-0.02em;text-shadow:0 2px 20px rgba(0,0,0,0.4);">
                  Built to Last.<br/>
                  <span style="color:#ea580c;">Built to Impress.</span>
                </h1>
                <p style="color:rgba(255,255,255,0.7);font-size:17px;line-height:1.7;max-width:540px;margin:0 0 36px;">
                  Apex Built delivers commercial construction projects on time, on budget, and to the highest standard. From design-and-construct to fitouts — we build what others can't.
                </p>
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                  <button style="background:linear-gradient(135deg,#ea580c,#b45309);color:white;font-size:14px;font-weight:700;padding:13px 26px;border-radius:8px;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(234,88,12,0.3);">
                    View Our Projects
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                  <button style="background:rgba(255,255,255,0.08);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.85);font-size:14px;font-weight:600;padding:13px 26px;border-radius:8px;cursor:pointer;">Request a Quote</button>
                </div>
              </div>
            </div>

            <!-- Stats -->
            <div style="background:#120c05;border-top:1px solid rgba(234,88,12,0.15);border-bottom:1px solid rgba(234,88,12,0.15);padding:28px 48px;">
              <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;max-width:860px;margin:0 auto;text-align:center;">
                {[
                  {val:'$2.4B+',label:'Projects Delivered'},
                  {val:'22 yrs',label:'Industry Experience'},
                  {val:'180+',label:'Projects Completed'},
                  {val:'100%',label:'On-Time Delivery Rate'},
                ].map(s=>(
                  <div>
                    <div style="font-size:26px;font-weight:900;color:#ea580c;line-height:1;">{s.val}</div>
                    <div style="color:rgba(254,243,226,0.35);font-size:11px;margin-top:4px;letter-spacing:0.06em;text-transform:uppercase;">{s.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Featured project -->
            <div style="background:#0a0703;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:48px;">
                <p style="color:#ea580c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Featured Work</p>
                <h2 style="font-size:30px;color:#fef3e2;font-weight:900;margin:0;">Recent Projects</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Docklands Commercial Tower',loc:'Melbourne CBD',type:'Design & Construct',val:'$48M',tag:'Completed 2024'},
                  {title:'Richmond Warehouse Conversion',loc:'Richmond, VIC',type:'Industrial Fitout',val:'$12M',tag:'Completed 2023'},
                  {title:'Southbank Office Campus',loc:'Southbank, VIC',type:'Commercial Construction',val:'$94M',tag:'In Progress'},
                ].map(p=>(
                  <div style="background:#120c05;border:1px solid rgba(234,88,12,0.12);border-radius:12px;overflow:hidden;cursor:pointer;" class="const-card">
                    <div style="height:140px;background:linear-gradient(135deg,#1a0e06,#2a1a0a);display:flex;align-items:center;justify-content:center;position:relative;">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(234,88,12,0.3)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                      <div style="position:absolute;top:10px;right:10px;background:rgba(234,88,12,0.15);border:1px solid rgba(234,88,12,0.25);color:#fb923c;font-size:9px;font-weight:700;padding:3px 8px;border-radius:10px;">{p.tag}</div>
                    </div>
                    <div style="padding:18px;">
                      <h3 style="font-size:14px;color:#fef3e2;font-weight:800;margin:0 0 6px;">{p.title}</h3>
                      <p style="color:rgba(254,243,226,0.4);font-size:12px;margin:0 0 10px;">{p.loc} · {p.type}</p>
                      <div style="font-size:18px;font-weight:900;color:#ea580c;">{p.val}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- PAGE 1: PROJECTS -->
          <div class="const-page hidden" data-page="1">
            <nav style="background:#0f0a06;border-bottom:1px solid rgba(234,88,12,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="const-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#ea580c,#b45309);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <span style="color:#fef3e2;font-size:15px;font-weight:800;">APEX BUILT</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Projects',g:'1'},{n:'Services',g:'2'}].map(item=>(
                  <span style="color:rgba(254,243,226,0.45);font-size:13px;cursor:pointer;" class="const-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#ea580c,#b45309);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;" class="const-nav" data-goto="3">Request a Quote</button>
              </div>
            </nav>
            <div style="background:#0a0703;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:52px;">
                <p style="color:#ea580c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Portfolio</p>
                <h2 style="font-size:38px;color:#fef3e2;font-weight:900;margin:0 0 14px;">Our Projects</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Docklands Commercial Tower',loc:'Melbourne CBD',type:'Design & Construct',val:'$48M',year:'2024'},
                  {title:'Richmond Warehouse Conversion',loc:'Richmond, VIC',type:'Industrial Fitout',val:'$12M',year:'2023'},
                  {title:'Southbank Office Campus',loc:'Southbank, VIC',type:'Commercial Construction',val:'$94M',year:'In Progress'},
                  {title:'Geelong Distribution Centre',loc:'Geelong, VIC',type:'Industrial Construction',val:'$31M',year:'2022'},
                  {title:'Collins Street Fitout',loc:'Melbourne CBD',type:'Commercial Fitout',val:'$8.5M',year:'2024'},
                  {title:'Dandenong Manufacturing Hub',loc:'Dandenong, VIC',type:'Industrial Build',val:'$62M',year:'2023'},
                ].map(p=>(
                  <div style="background:#120c05;border:1px solid rgba(234,88,12,0.12);border-radius:14px;overflow:hidden;cursor:pointer;display:flex;gap:0;" class="const-card">
                    <div style="width:100px;min-width:100px;background:linear-gradient(160deg,#1a0e06,#2a1a0a);display:flex;align-items:center;justify-content:center;">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(234,88,12,0.25)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </div>
                    <div style="padding:18px;flex:1;">
                      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                        <h3 style="font-size:14px;color:#fef3e2;font-weight:800;margin:0;">{p.title}</h3>
                        <span style="color:#ea580c;font-size:14px;font-weight:900;">{p.val}</span>
                      </div>
                      <p style="color:rgba(254,243,226,0.4);font-size:12px;margin:0 0 8px;">{p.type} · {p.loc}</p>
                      <span style="background:rgba(234,88,12,0.1);border:1px solid rgba(234,88,12,0.2);color:#fb923c;font-size:9px;font-weight:700;padding:3px 8px;border-radius:10px;">{p.year}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- PAGE 2: SERVICES -->
          <div class="const-page hidden" data-page="2">
            <nav style="background:#0f0a06;border-bottom:1px solid rgba(234,88,12,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="const-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#ea580c,#b45309);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <span style="color:#fef3e2;font-size:15px;font-weight:800;">APEX BUILT</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Projects',g:'1'},{n:'Services',g:'2'}].map(item=>(
                  <span style="color:rgba(254,243,226,0.45);font-size:13px;cursor:pointer;" class="const-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#ea580c,#b45309);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;" class="const-nav" data-goto="3">Request a Quote</button>
              </div>
            </nav>
            <div style="background:#0a0703;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:52px;">
                <p style="color:#ea580c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Capabilities</p>
                <h2 style="font-size:38px;color:#fef3e2;font-weight:900;margin:0 0 14px;">What We Build</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:18px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Design & Construct',desc:'End-to-end project delivery from concept and planning through to handover. One team, one contract, zero gaps.'},
                  {title:'Commercial Construction',desc:'Office towers, retail developments, mixed-use buildings — high-complexity projects delivered with precision.'},
                  {title:'Industrial & Warehousing',desc:'Distribution centres, manufacturing facilities, and cold storage built to exact specification.'},
                  {title:'Commercial Fitouts',desc:'Interior fitout for offices, hospitality, retail, and healthcare environments. Disruption-minimised delivery.'},
                  {title:'Structural Engineering',desc:'In-house engineering capability for complex structural challenges, enabling faster approvals and cleaner solutions.'},
                  {title:'Facilities Management',desc:'Post-handover maintenance, planned preventative maintenance programs, and building compliance management.'},
                ].map(s=>(
                  <div style="background:#120c05;border:1px solid rgba(234,88,12,0.12);border-radius:12px;padding:24px;cursor:pointer;" class="const-card">
                    <h3 style="font-size:15px;color:#fef3e2;font-weight:800;margin:0 0 8px;display:flex;align-items:center;gap:8px;">
                      <span style="width:6px;height:6px;background:#ea580c;border-radius:50%;display:inline-block;flex-shrink:0;"></span>
                      {s.title}
                    </h3>
                    <p style="color:rgba(254,243,226,0.4);font-size:13px;line-height:1.6;margin:0;">{s.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- PAGE 3: CONTACT -->
          <div class="const-page hidden" data-page="3">
            <nav style="background:#0f0a06;border-bottom:1px solid rgba(234,88,12,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="const-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#ea580c,#b45309);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <span style="color:#fef3e2;font-size:15px;font-weight:800;">APEX BUILT</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Projects',g:'1'},{n:'Services',g:'2'}].map(item=>(
                  <span style="color:rgba(254,243,226,0.45);font-size:13px;cursor:pointer;" class="const-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#ea580c,#b45309);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;" class="const-nav" data-goto="3">Request a Quote</button>
              </div>
            </nav>
            <div style="background:#0a0703;padding:72px 48px;">
              <div style="max-width:960px;margin:0 auto;display:grid;grid-template-columns:1fr 1.2fr;gap:56px;align-items:start;">
                <div>
                  <p style="color:#ea580c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Contact</p>
                  <h2 style="font-size:34px;color:#fef3e2;font-weight:900;margin:0 0 14px;line-height:1.2;">Request a Quote</h2>
                  <p style="color:rgba(254,243,226,0.45);font-size:15px;line-height:1.7;margin:0 0 36px;">Tell us about your project and a senior project manager will be in touch within one business day.</p>
                  <div style="display:flex;flex-direction:column;gap:16px;">
                    {[
                      {label:'Head Office',val:'12 Lorimer Street, Port Melbourne VIC 3207',icon:'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z'},
                      {label:'Phone',val:'+61 3 9600 2200',icon:'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.18 2 2 0 0 1 3.07 1h3a2 2 0 0 1 2 1.72 19.9 19.9 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 19.9 19.9 0 0 0 2.81.7A2 2 0 0 1 21 16z'},
                      {label:'Email',val:'projects@apexbuilt.com.au',icon:'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 6l-10 7L2 6'},
                    ].map(item=>(
                      <div style="display:flex;gap:14px;align-items:flex-start;">
                        <div style="width:36px;height:36px;min-width:36px;background:rgba(234,88,12,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon}/></svg>
                        </div>
                        <div>
                          <div style="color:rgba(254,243,226,0.35);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2px;">{item.label}</div>
                          <div style="color:#fef3e2;font-size:13px;">{item.val}</div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                <div style="background:#120c05;border:1px solid rgba(234,88,12,0.15);border-radius:16px;padding:32px;">
                  <h3 style="font-size:18px;color:#fef3e2;font-weight:800;margin:0 0 20px;">Project Enquiry</h3>
                  <div style="display:flex;flex-direction:column;gap:13px;">
