<script is:inline>
  const pages = document.querySelectorAll('.const-page');
  const viewport = document.getElementById('const-viewport');
  function goToPage(idx) {
    pages.forEach((p,i) => p.classList.toggle('hidden', i!==idx));
    if(viewport) viewport.scrollTop=0;
  }
  document.querySelectorAll('.const-nav[data-goto]').forEach(link => {
    link.addEventListener('click', () => goToPage(parseInt(link.dataset.goto)));
  });
  document.querySelectorAll('.const-logo').forEach(logo => {
    logo.addEventListener('click', () => goToPage(0));
  });
  document.querySelectorAll('.const-card').forEach(c => {
    c.addEventListener('mouseenter',()=>{ c.style.borderColor='rgba(234,88,12,0.35)'; c.style.background='#1a0f07'; });
    c.addEventListener('mouseleave',()=>{ c.style.borderColor='rgba(234,88,12,0.12)'; c.style.background='#120c05'; });
  });
</script>
