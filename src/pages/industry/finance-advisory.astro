<script is:inline>
  const pages = document.querySelectorAll('.fin-page');
  const viewport = document.getElementById('fin-viewport');
  function goToPage(idx) {
    pages.forEach((p,i) => p.classList.toggle('hidden', i!==idx));
    if(viewport) viewport.scrollTop=0;
  }
  document.querySelectorAll('.fin-nav[data-goto]').forEach(link => {
    link.addEventListener('click', () => goToPage(parseInt(link.dataset.goto)));
  });
  document.querySelectorAll('.fin-logo').forEach(logo => {
    logo.addEventListener('click', () => goToPage(0));
  });
  document.querySelectorAll('.fin-card').forEach(c => {
    c.addEventListener('mouseenter',()=>{ c.style.borderColor='rgba(8,145,178,0.35)'; c.style.background='#071420'; });
    c.addEventListener('mouseleave',()=>{ c.style.borderColor='rgba(8,145,178,0.12)'; c.style.background='#050f18'; });
  });
</script>
