---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar/Navbar.astro';
import Footer from '../../components/footer/Footer.astro';
import MockupViewToggle from '../../components/industry/MockupViewToggle.astro';
---

<Layout title="Finance & Advisory — Linova Group" description="Web design for business lenders, wealth managers & commercial insurance brokers.">
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden text-white" style="background: radial-gradient(ellipse at 50% 50%, #164e63 0%, #0c2e3d 45%, #04101a 100%);">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(8,145,178,0.22) 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 inline-block"></span>
        Finance & Advisory
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Websites That Inspire<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #67e8f9, #a5f3fc);">Financial Confidence</span>
      </h1>
      <p class="text-white/55 text-lg max-w-[540px] mx-auto leading-relaxed font-medium">
        Business lenders, wealth managers, and commercial brokers win clients on trust and track record. We build the digital presence that earns both — before a single meeting.
      </p>
    </div>
  </section>

  <!-- Interactive Showcase -->
  <section class="py-20 bg-[#07080f]">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400/60 mb-2">Live Example</p>
        <h2 class="text-white text-2xl sm:text-3xl font-bold mb-3">See What We'd Build for a Wealth Manager</h2>
        <p class="text-white/40 text-sm">Switch pages, hover elements, and explore the full design.</p>
      </div>

      <MockupViewToggle />

      <div class="mockup-switcher" data-view="desktop">
      <!-- Desktop browser mockup -->
      <div class="mockup-desktop rounded-2xl overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.6)] border border-white/10">
        <div class="flex items-center gap-3 px-5 py-3" style="background:#060f14; border-bottom:1px solid rgba(255,255,255,0.08);">
          <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
          <div class="flex-1 flex items-center gap-2 rounded-full px-4 py-1.5 ml-2 text-xs" style="background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.4); max-width:300px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            pinnacleadvisory.com.au
          </div>
        </div>

        <div style="height:620px;overflow-y:auto;overflow-x:hidden;" id="fin-viewport">

          <!-- PAGE 0: HOME -->
          <div class="fin-page" data-page="0">
            <nav style="background:#040c12;border-bottom:1px solid rgba(8,145,178,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="fin-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#0891b2,#0e7490);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <span style="color:#e0f7fa;font-size:15px;font-weight:700;letter-spacing:-0.01em;">Pinnacle Advisory</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Our Team',g:'2'}].map(item=>(
                  <span style="color:rgba(224,247,250,0.45);font-size:13px;cursor:pointer;" class="fin-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#0891b2,#0e7490);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="fin-nav" data-goto="3">Book a Consultation</button>
              </div>
            </nav>

            <!-- Hero (Video-First) -->
            <div style="position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;">
              <!-- Background video -->
              <video autoplay muted loop playsinline src="/videos/finance-advisory.mp4" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"></video>
              <!-- Dark overlay for text readability -->
              <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(3,10,16,0.92) 0%,rgba(4,12,20,0.75) 45%,rgba(4,12,20,0.5) 100%);pointer-events:none;"></div>
              <!-- Accent top line -->
              <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,#0891b2,transparent);"></div>

              <div style="position:relative;padding:96px 48px 80px;max-width:680px;">
                <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(8,145,178,0.15);border:1px solid rgba(8,145,178,0.3);padding:6px 14px;border-radius:20px;margin-bottom:28px;backdrop-filter:blur(8px);">
                  <span style="width:6px;height:6px;background:#06b6d4;border-radius:50%;"></span>
                  <span style="color:#67e8f9;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;">Wealth Management · Melbourne</span>
                </div>
                <h1 style="font-size:52px;font-weight:800;color:#ffffff;line-height:1.07;margin:0 0 20px;letter-spacing:-0.02em;text-shadow:0 2px 20px rgba(0,0,0,0.4);">
                  Grow.<br/>
                  <span style="background:linear-gradient(90deg,#67e8f9,#a5f3fc);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Protect.</span><br/>
                  Prosper.
                </h1>
                <p style="color:rgba(255,255,255,0.7);font-size:17px;line-height:1.7;max-width:540px;margin:0 0 36px;">
                  Pinnacle Advisory has managed over $2.1 billion in client wealth since 2006. We provide independent, fee-only financial advice for business owners and high-net-worth individuals.
                </p>
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                  <button style="background:linear-gradient(135deg,#0891b2,#0e7490);color:white;font-size:14px;font-weight:700;padding:13px 26px;border-radius:8px;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(8,145,178,0.3);">
                    Book a Free Consultation
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                  <button style="background:rgba(255,255,255,0.08);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.85);font-size:14px;font-weight:600;padding:13px 26px;border-radius:8px;cursor:pointer;">Our Approach</button>
                </div>
              </div>
            </div>

            <!-- Stats -->
            <div style="background:#050f18;border-top:1px solid rgba(8,145,178,0.15);border-bottom:1px solid rgba(8,145,178,0.15);padding:28px 48px;">
              <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;max-width:860px;margin:0 auto;text-align:center;">
                {[
                  {val:'$2.1B',label:'Assets Under Advice'},
                  {val:'18 yrs',label:'In Practice'},
                  {val:'420+',label:'Client Families'},
                  {val:'100%',label:'Fee-Only, Independent'},
                ].map(s=>(
                  <div>
                    <div style="font-size:26px;font-weight:800;color:#06b6d4;line-height:1;">{s.val}</div>
                    <div style="color:rgba(224,247,250,0.35);font-size:11px;margin-top:4px;letter-spacing:0.06em;text-transform:uppercase;">{s.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Services preview -->
            <div style="background:#030a10;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:48px;">
                <p style="color:#0891b2;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">What We Do</p>
                <h2 style="font-size:30px;color:#e0f7fa;font-weight:800;margin:0;">Our Services</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Wealth Management',desc:'Personalised investment portfolios, tax strategies, and estate planning for long-term financial security.',icon:'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'},
                  {title:'Business Advisory',desc:'M&A advisory, business structuring, and exit planning for owners planning their next chapter.',icon:'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2'},
                  {title:'SMSF & Retirement',desc:'Self-managed superannuation fund strategy, compliance, and pension phase planning.',icon:'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'},
                ].map(s=>(
                  <div style="background:#050f18;border:1px solid rgba(8,145,178,0.12);border-radius:12px;padding:24px;cursor:pointer;" class="fin-card">
                    <div style="width:40px;height:40px;background:rgba(8,145,178,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={s.icon}/></svg>
                    </div>
                    <h3 style="font-size:15px;color:#e0f7fa;font-weight:700;margin:0 0 8px;">{s.title}</h3>
                    <p style="color:rgba(224,247,250,0.4);font-size:13px;line-height:1.6;margin:0;">{s.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Testimonial -->
            <div style="background:#040c12;border-top:1px solid rgba(8,145,178,0.1);padding:64px 48px;text-align:center;">
              <div style="max-width:640px;margin:0 auto;">
                <div style="color:#0891b2;font-size:48px;line-height:1;margin-bottom:16px;">"</div>
                <p style="font-size:19px;color:#e0f7fa;line-height:1.7;margin:0 0 28px;font-style:italic;">
                  Pinnacle gave us the confidence to sell our business at the right time, for the right price. Their advice over the preceding three years was worth every dollar — and then some.
                </p>
                <div style="display:flex;align-items:center;justify-content:center;gap:12px;">
                  <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#0c2a3a,#164e63);display:flex;align-items:center;justify-content:center;">
                    <span style="color:#67e8f9;font-size:14px;font-weight:700;">GL</span>
                  </div>
                  <div style="text-align:left;">
                    <div style="color:#e0f7fa;font-size:14px;font-weight:600;">Gina Lau</div>
                    <div style="color:rgba(224,247,250,0.4);font-size:12px;">Former Director, Lau Logistics</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- PAGE 1: SERVICES -->
          <div class="fin-page hidden" data-page="1">
            <nav style="background:#040c12;border-bottom:1px solid rgba(8,145,178,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="fin-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#0891b2,#0e7490);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <span style="color:#e0f7fa;font-size:15px;font-weight:700;">Pinnacle Advisory</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Our Team',g:'2'}].map(item=>(
                  <span style="color:rgba(224,247,250,0.45);font-size:13px;cursor:pointer;" class="fin-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#0891b2,#0e7490);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="fin-nav" data-goto="3">Book a Consultation</button>
              </div>
            </nav>
            <div style="background:#030a10;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:52px;">
                <p style="color:#06b6d4;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">What We Offer</p>
                <h2 style="font-size:38px;color:#e0f7fa;font-weight:800;margin:0 0 14px;">Our Services</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:18px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Wealth Management',desc:'Tailored investment portfolios built around your goals, risk tolerance, and time horizon — reviewed quarterly with you.',icon:'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'},
                  {title:'Business Advisory',desc:'Strategic advice for business owners — from structuring and growth through to succession planning and exit strategy.',icon:'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2'},
                  {title:'SMSF & Retirement Planning',desc:'Comprehensive self-managed super fund strategy, trustee compliance, and pension phase transition planning.',icon:'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'},
                  {title:'Estate Planning',desc:'Structures that ensure your wealth transfers to the right people in the right way — with minimal tax and no surprises.',icon:'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 0 0 1 1h3m10-11l2 2m-2-2v10a1 1 0 0 0-1 1h-3m-6 0a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h4'},
                  {title:'Commercial Insurance',desc:'Broker-independent review of your business insurance to ensure you are covered where it matters — and not over-paying.',icon:'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'},
                  {title:'Mortgage & Lending',desc:'Commercial property finance, business loans, and debt restructuring from a network of 35+ lenders.',icon:'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'},
                ].map(s=>(
                  <div style="background:#050f18;border:1px solid rgba(8,145,178,0.12);border-radius:12px;padding:24px;display:flex;gap:16px;cursor:pointer;" class="fin-card">
                    <div style="width:44px;height:44px;min-width:44px;background:rgba(8,145,178,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={s.icon}/></svg>
                    </div>
                    <div>
                      <h3 style="font-size:15px;color:#e0f7fa;font-weight:700;margin:0 0 7px;">{s.title}</h3>
                      <p style="color:rgba(224,247,250,0.4);font-size:13px;line-height:1.6;margin:0;">{s.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- PAGE 2: TEAM -->
          <div class="fin-page hidden" data-page="2">
            <nav style="background:#040c12;border-bottom:1px solid rgba(8,145,178,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="fin-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#0891b2,#0e7490);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <span style="color:#e0f7fa;font-size:15px;font-weight:700;">Pinnacle Advisory</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Our Team',g:'2'}].map(item=>(
                  <span style="color:rgba(224,247,250,0.45);font-size:13px;cursor:pointer;" class="fin-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#0891b2,#0e7490);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="fin-nav" data-goto="3">Book a Consultation</button>
              </div>
            </nav>
            <div style="background:#030a10;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:52px;">
                <p style="color:#06b6d4;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Our Advisers</p>
                <h2 style="font-size:38px;color:#e0f7fa;font-weight:800;margin:0 0 14px;">The Team</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:960px;margin:0 auto;">
                {[
                  {name:'William Chen',title:'Principal Adviser',spec:'Wealth Management & Business Advisory',quals:'CFP®, CPA, B.Comm (Finance)',exp:'21 yrs',initials:'WC'},
                  {name:'Rebecca Santos',title:'Senior Adviser',spec:'Retirement & SMSF Planning',quals:'CFP®, SMSF Specialist Adviser',exp:'14 yrs',initials:'RS'},
                  {name:'James O\'Brien',title:'Senior Adviser',spec:'Estate Planning & Insurance',quals:'CFP®, Dip Financial Planning',exp:'12 yrs',initials:'JO'},
                  {name:'Natalie Tran',title:'Associate Adviser',spec:'Investment Strategy',quals:'B.Comm (Economics), DFP',exp:'7 yrs',initials:'NT'},
                  {name:'Samuel Park',title:'Associate Adviser',spec:'Business Lending & Mortgages',quals:'Cert IV Finance, Dip Finance',exp:'6 yrs',initials:'SP'},
                  {name:'Emma Liu',title:'Client Services',spec:'Client Experience & Onboarding',quals:'B.Business Administration',exp:'4 yrs',initials:'EL'},
                ].map(p=>(
                  <div style="background:#050f18;border:1px solid rgba(8,145,178,0.12);border-radius:12px;padding:22px;cursor:pointer;" class="fin-card">
                    <div style="width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#0c2a3a,#164e63);border:2px solid rgba(8,145,178,0.25);display:flex;align-items:center;justify-content:center;margin-bottom:12px;">
                      <span style="color:#67e8f9;font-size:14px;font-weight:700;">{p.initials}</span>
                    </div>
                    <h3 style="font-size:14px;color:#e0f7fa;font-weight:700;margin:0 0 2px;">{p.name}</h3>
                    <p style="color:#06b6d4;font-size:11px;font-weight:600;margin:0 0 5px;">{p.title}</p>
                    <p style="color:rgba(224,247,250,0.4);font-size:12px;margin:0 0 10px;line-height:1.5;">{p.spec}</p>
                    <div style="border-top:1px solid rgba(8,145,178,0.1);padding-top:8px;display:flex;justify-content:space-between;">
                      <span style="color:rgba(224,247,250,0.25);font-size:10px;">{p.quals}</span>
                      <span style="color:#06b6d4;font-size:11px;font-weight:600;">{p.exp}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- PAGE 3: CONTACT -->
          <div class="fin-page hidden" data-page="3">
            <nav style="background:#040c12;border-bottom:1px solid rgba(8,145,178,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="fin-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#0891b2,#0e7490);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <span style="color:#e0f7fa;font-size:15px;font-weight:700;">Pinnacle Advisory</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Our Team',g:'2'}].map(item=>(
                  <span style="color:rgba(224,247,250,0.45);font-size:13px;cursor:pointer;" class="fin-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#0891b2,#0e7490);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="fin-nav" data-goto="3">Book a Consultation</button>
              </div>
            </nav>
