<script is:inline>
  const tabs = document.querySelectorAll('.mktg-tab');
  const pages = document.querySelectorAll('.mktg-page');
  const viewport = document.getElementById('mktg-viewport');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const idx = parseInt(tab.dataset.tab);
      tabs.forEach((t,i) => { t.style.background=i===idx?'rgba(5,150,105,0.25)':'transparent'; t.style.color=i===idx?'rgba(255,255,255,0.9)':'rgba(255,255,255,0.35)'; });
      pages.forEach((p,i) => p.classList.toggle('hidden', i!==idx));
      if(viewport) viewport.scrollTop=0;
    });
  });
  document.querySelectorAll('.mktg-card').forEach(c => {
    c.addEventListener('mouseenter',()=>{ c.style.borderColor='rgba(5,150,105,0.35)'; c.style.background='#081209'; });
    c.addEventListener('mouseleave',()=>{ c.style.borderColor='rgba(5,150,105,0.12)'; c.style.background='#060e0a'; });
  });
</script>
