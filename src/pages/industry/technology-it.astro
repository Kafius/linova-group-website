<script is:inline>
  const pages = document.querySelectorAll('.tech-page');
  const viewport = document.getElementById('tech-viewport');
  function goToPage(idx) {
    pages.forEach((p,i) => p.classList.toggle('hidden', i!==idx));
    if(viewport) viewport.scrollTop=0;
  }
  document.querySelectorAll('.tech-nav[data-goto]').forEach(link => {
    link.addEventListener('click', () => goToPage(parseInt(link.dataset.goto)));
  });
  document.querySelectorAll('.tech-logo').forEach(logo => {
    logo.addEventListener('click', () => goToPage(0));
  });
  document.querySelectorAll('.tech-card').forEach(c => {
    c.addEventListener('mouseenter',()=>{ c.style.borderColor='rgba(124,58,237,0.35)'; c.style.background='#120f22'; });
    c.addEventListener('mouseleave',()=>{ c.style.borderColor='rgba(124,58,237,0.12)'; c.style.background='#0d0b1a'; });
  });
</script>
