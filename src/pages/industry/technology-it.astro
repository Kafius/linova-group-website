---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar/Navbar.astro';
import Footer from '../../components/footer/Footer.astro';
import MockupViewToggle from '../../components/industry/MockupViewToggle.astro';
---

<Layout title="Technology & IT — Linova Group" description="Web design for SaaS platforms, managed service providers & cybersecurity firms.">
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden text-white" style="background: radial-gradient(ellipse at 50% 50%, #3b1f6e 0%, #1e0f4b 45%, #10071e 100%);">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(124,58,237,0.25) 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-violet-400 inline-block"></span>
        Technology & IT
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Websites That Match<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #a78bfa, #60a5fa);">Your Technical Edge</span>
      </h1>
      <p class="text-white/55 text-lg max-w-[540px] mx-auto leading-relaxed font-medium">
        SaaS platforms, MSPs, and cybersecurity firms need a site as sharp as their product. We build digital presences that convert technical buyers and enterprise decision-makers.
      </p>
    </div>
  </section>

  <!-- Interactive Showcase -->
  <section class="py-20 bg-[#07080f]">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-violet-400/60 mb-2">Live Example</p>
        <h2 class="text-white text-2xl sm:text-3xl font-bold mb-3">See What We'd Build for an MSP</h2>
        <p class="text-white/40 text-sm">Switch pages, hover elements, and explore the full design.</p>
      </div>

      <MockupViewToggle />

      <div class="mockup-switcher" data-view="desktop">
      <!-- Browser frame -->
      <!-- Desktop browser mockup -->
      <div class="mockup-desktop rounded-2xl overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.6)] border border-white/10">
        <!-- Chrome -->
        <div class="flex items-center gap-3 px-5 py-3" style="background:#12101e; border-bottom:1px solid rgba(255,255,255,0.08);">
          <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
          <div class="flex-1 flex items-center gap-2 rounded-full px-4 py-1.5 ml-2 text-xs" style="background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.4); max-width:300px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            vantagesystems.com.au
          </div>
        </div>

        <!-- Viewport -->
        <div style="height:620px;overflow-y:auto;overflow-x:hidden;" id="tech-viewport">

          <!-- PAGE 0: HOME -->
          <div class="tech-page" data-page="0">
            <nav style="background:#0d0b1a;border-bottom:1px solid rgba(124,58,237,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="tech-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#7c3aed,#3b82f6);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                </div>
                <span style="color:#e2d9f3;font-size:15px;font-weight:700;letter-spacing:-0.01em;">Vantage Systems</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Security',g:'2'}].map(item => (
                  <span style="color:rgba(226,217,243,0.45);font-size:13px;cursor:pointer;" class="tech-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#7c3aed,#5b21b6);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="tech-nav" data-goto="3">Get Support</button>
              </div>
            </nav>

            <!-- Hero (Video-First) -->
            <div style="position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;">
              <!-- Background video -->
              <video autoplay muted loop playsinline src="/videos/technology-it.mp4" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"></video>
              <!-- Dark overlay for text readability -->
              <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(10,8,20,0.93) 0%,rgba(15,12,31,0.78) 45%,rgba(8,13,26,0.5) 100%);pointer-events:none;"></div>
              <!-- Accent top line -->
              <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,#7c3aed,transparent);"></div>

              <div style="position:relative;padding:96px 48px 80px;max-width:700px;">
                <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.3);padding:6px 14px;border-radius:20px;margin-bottom:28px;backdrop-filter:blur(8px);">
                  <span style="width:6px;height:6px;background:#7c3aed;border-radius:50%;display:inline-block;"></span>
                  <span style="color:#a78bfa;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;">Managed IT · Melbourne & Sydney</span>
                </div>
                <h1 style="font-size:52px;font-weight:800;color:#ffffff;line-height:1.05;margin:0 0 20px;letter-spacing:-0.02em;text-shadow:0 2px 20px rgba(0,0,0,0.4);">
                  Your IT.<br />
                  <span style="background:linear-gradient(90deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Handled.</span>
                </h1>
                <p style="color:rgba(255,255,255,0.7);font-size:17px;line-height:1.7;max-width:540px;margin:0 0 36px;">
                  Vantage Systems is Melbourne's most trusted managed IT provider. From 24/7 helpdesk to enterprise cybersecurity — we make technology invisible so your business can focus on growth.
                </p>
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                  <button style="background:linear-gradient(135deg,#7c3aed,#5b21b6);color:white;font-size:14px;font-weight:700;padding:13px 26px;border-radius:8px;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(124,58,237,0.3);">
                    Get a Free IT Audit
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                  <button style="background:rgba(255,255,255,0.08);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.85);font-size:14px;font-weight:600;padding:13px 26px;border-radius:8px;cursor:pointer;">View Services</button>
                </div>
              </div>
            </div>

            <!-- Stats -->
            <div style="background:#0d0b1a;border-top:1px solid rgba(124,58,237,0.15);border-bottom:1px solid rgba(124,58,237,0.15);padding:28px 48px;">
              <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;max-width:860px;margin:0 auto;text-align:center;">
                {[
                  {val:'99.98%',label:'Uptime Guaranteed'},
                  {val:'<4 min',label:'Avg. Response Time'},
                  {val:'340+',label:'Businesses Supported'},
                  {val:'24/7',label:'Helpdesk Coverage'},
                ].map(s => (
                  <div>
                    <div style="font-size:26px;font-weight:800;color:#a78bfa;line-height:1;">{s.val}</div>
                    <div style="color:rgba(226,217,243,0.35);font-size:11px;margin-top:4px;letter-spacing:0.06em;text-transform:uppercase;">{s.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Services preview -->
            <div style="background:#080c14;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:48px;">
                <p style="color:#7c3aed;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">What We Cover</p>
                <h2 style="font-size:30px;color:#f0ebff;font-weight:800;margin:0;">IT Services Built for Business</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Managed IT Support',desc:'Proactive monitoring, helpdesk, and on-site support — all under one flat monthly fee.',icon:'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18'},
                  {title:'Cybersecurity',desc:'Threat detection, endpoint protection, and compliance across your entire organisation.',icon:'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'},
                  {title:'Cloud & Infrastructure',desc:'Microsoft 365, Azure, and hybrid cloud environments designed and managed for you.',icon:'M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'},
                ].map(s => (
                  <div style="background:#0d0b1a;border:1px solid rgba(124,58,237,0.12);border-radius:12px;padding:24px;cursor:pointer;" class="tech-card">
                    <div style="width:40px;height:40px;background:rgba(124,58,237,0.12);border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={s.icon}/></svg>
                    </div>
                    <h3 style="font-size:15px;color:#f0ebff;font-weight:700;margin:0 0 8px;">{s.title}</h3>
                    <p style="color:rgba(226,217,243,0.4);font-size:13px;line-height:1.6;margin:0;">{s.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Testimonial -->
            <div style="background:#0a0814;border-top:1px solid rgba(124,58,237,0.1);padding:64px 48px;text-align:center;">
              <div style="max-width:640px;margin:0 auto;">
                <div style="display:flex;justify-content:center;gap:3px;margin-bottom:20px;">
                  {[1,2,3,4,5].map(() => (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#7c3aed" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                </div>
                <p style="font-size:18px;color:#f0ebff;line-height:1.7;margin:0 0 24px;font-style:italic;">
                  "We had a ransomware incident at 2am on a Sunday. Vantage had us back online within 3 hours with zero data loss. I'd recommend them to any business that takes security seriously."
                </p>
                <div style="display:flex;align-items:center;justify-content:center;gap:12px;">
                  <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#2d1b69,#4c1d95);display:flex;align-items:center;justify-content:center;">
                    <span style="color:#a78bfa;font-size:13px;font-weight:700;">MK</span>
                  </div>
                  <div style="text-align:left;">
                    <div style="color:#f0ebff;font-size:13px;font-weight:600;">Mark Kowalski</div>
                    <div style="color:rgba(226,217,243,0.4);font-size:12px;">COO, Pacific Logistics Group</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- PAGE 1: SERVICES -->
          <div class="tech-page hidden" data-page="1">
            <nav style="background:#0d0b1a;border-bottom:1px solid rgba(124,58,237,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="tech-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#7c3aed,#3b82f6);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                </div>
                <span style="color:#e2d9f3;font-size:15px;font-weight:700;">Vantage Systems</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Security',g:'2'}].map(item=>(
                  <span style="color:rgba(226,217,243,0.45);font-size:13px;cursor:pointer;" class="tech-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#7c3aed,#5b21b6);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="tech-nav" data-goto="3">Get Support</button>
              </div>
            </nav>
            <div style="background:#080c14;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:52px;">
                <p style="color:#a78bfa;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Full Stack IT</p>
                <h2 style="font-size:38px;color:#f0ebff;font-weight:800;margin:0 0 14px;">Our Services</h2>
                <p style="color:rgba(226,217,243,0.45);font-size:15px;max-width:460px;margin:0 auto;line-height:1.6;">Everything your business needs from a single trusted IT partner.</p>
              </div>
              <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:18px;max-width:960px;margin:0 auto;">
                {[
                  {title:'Managed IT Support',desc:'24/7 helpdesk, proactive monitoring, patch management, and on-site technicians when you need them.',icon:'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18'},
                  {title:'Cybersecurity',desc:'Endpoint protection, email filtering, penetration testing, and incident response planning.',icon:'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'},
                  {title:'Cloud Solutions',desc:'Microsoft 365, Azure and hybrid cloud design, migration, and ongoing management.',icon:'M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'},
                  {title:'Network & Infrastructure',desc:'Structured cabling, firewall configuration, Wi-Fi, and server room builds from the ground up.',icon:'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z'},
                  {title:'Backup & Disaster Recovery',desc:'Automated backups, offsite replication, and tested recovery plans — so downtime never becomes data loss.',icon:'M4 16v1a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-1m-4-8l-4-4m0 0L8 8m4-4v12'},
                  {title:'IT Strategy & vCIO',desc:'Quarterly technology roadmaps, vendor management, and board-level reporting from senior IT advisors.',icon:'M9 19v-6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2zm0 0V9a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v10m-6 0a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2m0 0V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2z'},
                ].map(s => (
                  <div style="background:#0d0b1a;border:1px solid rgba(124,58,237,0.12);border-radius:12px;padding:24px;display:flex;gap:16px;cursor:pointer;" class="tech-card">
                    <div style="width:44px;height:44px;min-width:44px;background:rgba(124,58,237,0.12);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={s.icon}/></svg>
                    </div>
                    <div>
                      <h3 style="font-size:15px;color:#f0ebff;font-weight:700;margin:0 0 7px;">{s.title}</h3>
                      <p style="color:rgba(226,217,243,0.4);font-size:13px;line-height:1.6;margin:0;">{s.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- PAGE 2: SECURITY -->
          <div class="tech-page hidden" data-page="2">
            <nav style="background:#0d0b1a;border-bottom:1px solid rgba(124,58,237,0.2);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="tech-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#7c3aed,#3b82f6);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                </div>
                <span style="color:#e2d9f3;font-size:15px;font-weight:700;">Vantage Systems</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Services',g:'1'},{n:'Security',g:'2'}].map(item=>(
                  <span style="color:rgba(226,217,243,0.45);font-size:13px;cursor:pointer;" class="tech-nav" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#7c3aed,#5b21b6);color:white;font-size:12px;font-weight:700;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;" class="tech-nav" data-goto="3">Get Support</button>
              </div>
            </nav>
            <div style="background:#080c14;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:52px;">
                <p style="color:#a78bfa;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Cybersecurity</p>
                <h2 style="font-size:38px;color:#f0ebff;font-weight:800;margin:0 0 14px;">Protecting Your Business,<br />Around the Clock</h2>
                <p style="color:rgba(226,217,243,0.45);font-size:15px;max-width:480px;margin:0 auto;line-height:1.6;">Cyber threats don't keep business hours. Our security stack keeps you protected 24/7.</p>
              </div>
              <!-- Threat dashboard mockup -->
              <div style="max-width:840px;margin:0 auto 40px;background:#0d0b1a;border:1px solid rgba(124,58,237,0.2);border-radius:16px;overflow:hidden;">
                <div style="padding:16px 20px;border-bottom:1px solid rgba(124,58,237,0.1);display:flex;align-items:center;justify-content:space-between;">
                  <span style="color:#f0ebff;font-size:13px;font-weight:700;">Security Operations Dashboard</span>
                  <span style="background:rgba(34,197,94,0.15);color:#4ade80;font-size:10px;font-weight:700;padding:4px 10px;border-radius:20px;border:1px solid rgba(34,197,94,0.2);">● All Systems Secure</span>
                </div>
                <div style="padding:20px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:4px;">
                  {[
                    {label:'Threats Blocked Today',val:'247',color:'#a78bfa'},
                    {label:'Endpoints Protected',val:'184',color:'#60a5fa'},
                    {label:'Emails Filtered',val:'3,821',color:'#34d399'},
                    {label:'Uptime This Month',val:'99.98%',color:'#fbbf24'},
                  ].map(m => (
                    <div style="background:#080c14;border:1px solid rgba(124,58,237,0.1);border-radius:10px;padding:14px;">
                      <div style={`font-size:22px;font-weight:800;color:${m.color};line-height:1;margin-bottom:4px;`}>{m.val}</div>
                      <div style="color:rgba(226,217,243,0.35);font-size:10px;">{m.label}</div>
                    </div>
                  ))}
                </div>
                <div style="padding:0 20px 20px;">
                  <div style="background:#080c14;border:1px solid rgba(124,58,237,0.1);border-radius:10px;padding:14px;">
                    <div style="color:#f0ebff;font-size:11px;font-weight:600;margin-bottom:10px;">Recent Events</div>
                    {[
                      {time:'09:42',event:'Phishing email blocked — finance@spoofed-domain.com',sev:'Medium',color:'#fbbf24'},
                      {time:'08:17',event:'Brute force login attempt — RDP port 3389',sev:'High',color:'#f87171'},
                      {time:'07:55',event:'Malware signature detected and quarantined',sev:'High',color:'#f87171'},
                      {time:'06:30',event:'Patch deployment completed — 12 endpoints',sev:'Info',color:'#60a5fa'},
                    ].map(e => (
                      <div style="display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(124,58,237,0.07);">
                        <span style="color:rgba(226,217,243,0.3);font-size:10px;font-family:monospace;min-width:36px;">{e.time}</span>
                        <span style="color:rgba(226,217,243,0.6);font-size:11px;flex:1;">{e.event}</span>
                        <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:10px;background:${e.color}18;color:${e.color};`}>{e.sev}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- PAGE 3: GET SUPPORT -->
          <div class="tech-page hidden" data-page="3">
