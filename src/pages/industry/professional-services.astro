---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar/Navbar.astro';
import Footer from '../../components/footer/Footer.astro';
import MockupViewToggle from '../../components/industry/MockupViewToggle.astro';
---

<Layout title="Professional Services — Linova Group" description="Web design for law firms, consultancies & accounting practices that win clients on credibility.">
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden text-white" style="background: radial-gradient(ellipse at 50% 50%, #2a2b6e 0%, #1a1b4b 45%, #16172f 100%);">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(109,40,217,0.2) 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
        Professional Services
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Websites That Win<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #fde68a, #fbbf24);">High-Value Clients</span>
      </h1>
      <p class="text-white/55 text-lg max-w-[540px] mx-auto leading-relaxed font-medium">
        Law firms, consultancies, and accounting practices don't close clients on price — they close on credibility. We build the digital presence that earns it.
      </p>
    </div>
  </section>

  <!-- Interactive Showcase -->
  <section class="py-20 bg-[#07080f]">
    <div class="max-w-[1200px] mx-auto px-6">

      <!-- Label -->
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-400/60 mb-2">Live Example</p>
        <h2 class="text-white text-2xl sm:text-3xl font-bold mb-3">See What We'd Build for a Law Firm</h2>
        <p class="text-white/40 text-sm">Interact with the site below — switch pages, hover elements, explore the full design.</p>
      </div>

      <MockupViewToggle />

      <div class="mockup-switcher" data-view="desktop">
      <!-- Browser frame -->
      <!-- Desktop browser mockup -->
      <div class="mockup-desktop rounded-2xl overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.6)] border border-white/10">

        <!-- Chrome bar -->
        <div class="flex items-center gap-3 px-5 py-3" style="background:#1a1b2e; border-bottom:1px solid rgba(255,255,255,0.08);">
          <span class="w-3 h-3 rounded-full bg-red-400/80 cursor-pointer"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400/80 cursor-pointer"></span>
          <span class="w-3 h-3 rounded-full bg-green-400/80 cursor-pointer"></span>
          <div class="flex-1 flex items-center gap-2 rounded-full px-4 py-1.5 ml-2 text-xs" style="background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.4); max-width:320px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            mercer-partners.com.au
          </div>
          
        </div>

        <!-- Website viewport -->
        <div style="height:620px; overflow-y:auto; overflow-x:hidden;" id="law-viewport">

          <!-- ═══════════════════════════════ PAGE 0: HOME ═══════════════════════════════ -->
          <div class="law-page" data-page="0">
            <!-- Nav -->
            <nav style="background:#0a0e1a; border-bottom:1px solid rgba(201,168,76,0.15); padding:0 48px; height:64px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50;">
              <div style="display:flex; align-items:center; gap:10px;cursor:pointer;" class="law-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#c9a84c,#8a6f2e);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M8 6h8"/><path d="M7 3h10"/></svg>
                </div>
                <span style="color:#f0e6c8;font-family:Georgia,serif;font-size:16px;font-weight:700;letter-spacing:0.02em;">Mercer & Partners</span>
              </div>
              <div style="display:flex;align-items:center;gap:28px;">
                {[{n:'Practice Areas',g:'1'},{n:'Our Team',g:'2'}].map(item => (
                  <span style="color:rgba(240,230,200,0.55);font-size:13px;cursor:pointer;transition:color 0.2s;" class="law-nav-link" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#c9a84c,#a8872e);color:#0a0e1a;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;letter-spacing:0.04em;" class="law-nav-link" data-goto="3">Book a Consultation</button>
              </div>
            </nav>

            <!-- Hero (Video-First) -->
            <div style="position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;">
              <!-- Background video -->
              <video autoplay muted loop playsinline src="/videos/professional-services.mp4" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"></video>
              <!-- Dark overlay for text readability -->
              <div style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(6,10,20,0.93) 0%,rgba(10,16,32,0.78) 45%,rgba(10,16,32,0.5) 100%);pointer-events:none;"></div>
              <!-- Gold accent line -->
              <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#c9a84c,transparent);"></div>

              <div style="position:relative;padding:96px 48px 80px;max-width:680px;">
                <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);padding:6px 14px;border-radius:20px;margin-bottom:28px;backdrop-filter:blur(8px);">
                  <span style="width:6px;height:6px;background:#c9a84c;border-radius:50%;display:inline-block;"></span>
                  <span style="color:#c9a84c;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;">Commercial Law · Melbourne CBD</span>
                </div>
                <h1 style="font-family:Georgia,serif;font-size:52px;font-weight:700;color:#ffffff;line-height:1.1;margin:0 0 20px;letter-spacing:-0.01em;text-shadow:0 2px 20px rgba(0,0,0,0.4);">
                  Justice.<br />
                  <span style="color:#c9a84c;">Strategy.</span><br />
                  Results.
                </h1>
                <p style="color:rgba(255,255,255,0.7);font-size:17px;line-height:1.7;max-width:520px;margin:0 0 36px;">
                  Mercer & Partners has represented Australia's most demanding commercial clients for over three decades. We don't just advise — we advocate.
                </p>
                <div style="display:flex;gap:14px;flex-wrap:wrap;">
                  <button style="background:linear-gradient(135deg,#c9a84c,#a8872e);color:#0a0e1a;font-size:14px;font-weight:700;padding:14px 28px;border-radius:8px;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(201,168,76,0.3);">
                    Book a Free Consultation
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                  <button style="background:rgba(255,255,255,0.08);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.85);font-size:14px;font-weight:600;padding:14px 28px;border-radius:8px;cursor:pointer;">
                    View Our Results
                  </button>
                </div>
              </div>
            </div>

            <!-- Stats bar -->
            <div style="background:#0d1525;border-top:1px solid rgba(201,168,76,0.12);border-bottom:1px solid rgba(201,168,76,0.12);padding:28px 48px;">
              <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;max-width:860px;margin:0 auto;text-align:center;">
                {[
                  { val: '38+', label: 'Years in Practice' },
                  { val: '1,400+', label: 'Cases Won' },
                  { val: '$3.2B', label: 'Recovered for Clients' },
                  { val: '97%', label: 'Client Satisfaction' },
                ].map(s => (
                  <div>
                    <div style="font-family:Georgia,serif;font-size:28px;font-weight:700;color:#c9a84c;line-height:1;">{s.val}</div>
                    <div style="color:rgba(240,230,200,0.4);font-size:11px;margin-top:4px;letter-spacing:0.06em;text-transform:uppercase;">{s.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Practice areas preview -->
            <div style="background:#080c18;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:48px;">
                <p style="color:#c9a84c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">Our Expertise</p>
                <h2 style="font-family:Georgia,serif;font-size:32px;color:#f0e6c8;font-weight:700;margin:0;">Practice Areas</h2>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:960px;margin:0 auto;">
                {[
                  { title:'Commercial Litigation', desc:'Resolving high-stakes business disputes through strategic advocacy and negotiation.', icon:'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2' },
                  { title:'Mergers & Acquisitions', desc:'End-to-end legal guidance on corporate transactions, due diligence, and deal structuring.', icon:'M16 16s-1.5-2-4-2-4 2-4 2M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z' },
                  { title:'Employment Law', desc:'Protecting businesses and executives across workplace disputes, contracts, and compliance.', icon:'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75' },
                ].map(area => (
                  <div style="background:#0d1525;border:1px solid rgba(201,168,76,0.1);border-radius:12px;padding:28px;cursor:pointer;transition:border-color 0.2s;" class="law-card">
                    <div style="width:40px;height:40px;background:rgba(201,168,76,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={area.icon}/></svg>
                    </div>
                    <h3 style="font-family:Georgia,serif;font-size:16px;color:#f0e6c8;font-weight:700;margin:0 0 8px;">{area.title}</h3>
                    <p style="color:rgba(240,230,200,0.45);font-size:13px;line-height:1.6;margin:0;">{area.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Testimonial -->
            <div style="background:#0a0e1a;border-top:1px solid rgba(201,168,76,0.1);padding:72px 48px;text-align:center;">
              <div style="max-width:680px;margin:0 auto;">
                <div style="color:#c9a84c;font-size:48px;font-family:Georgia,serif;line-height:1;margin-bottom:16px;">"</div>
                <p style="font-family:Georgia,serif;font-size:20px;color:#f0e6c8;line-height:1.7;margin:0 0 28px;font-style:italic;">
                  Mercer & Partners didn't just win our case — they changed the outcome of our entire business. The strategic counsel we received was unlike anything we'd experienced from previous firms.
                </p>
                <div style="display:flex;align-items:center;justify-content:center;gap:12px;">
                  <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#1e3a5f,#2d5a8e);display:flex;align-items:center;justify-content:center;">
                    <span style="color:#93c5fd;font-size:14px;font-weight:700;">RH</span>
                  </div>
                  <div style="text-align:left;">
                    <div style="color:#f0e6c8;font-size:14px;font-weight:600;">Richard Hammond</div>
                    <div style="color:rgba(240,230,200,0.4);font-size:12px;">CEO, Hammond Industrial Group</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- ═══════════════════════════════ PAGE 1: PRACTICE AREAS ═══════════════════════════════ -->
          <div class="law-page hidden" data-page="1">
            <nav style="background:#0a0e1a;border-bottom:1px solid rgba(201,168,76,0.15);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="law-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#c9a84c,#8a6f2e);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M8 6h8M7 3h10"/></svg>
                </div>
                <span style="color:#f0e6c8;font-family:Georgia,serif;font-size:16px;font-weight:700;">Mercer & Partners</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Practice Areas',g:'1'},{n:'Our Team',g:'2'}].map(item=>(
                  <span style="color:rgba(240,230,200,0.55);font-size:13px;cursor:pointer;" class="law-nav-link" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#c9a84c,#a8872e);color:#0a0e1a;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;letter-spacing:0.04em;" class="law-nav-link" data-goto="3">Book a Consultation</button>
              </div>
            </nav>
            <div style="background:#080c18;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:56px;">
                <p style="color:#c9a84c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">What We Do</p>
                <h2 style="font-family:Georgia,serif;font-size:40px;color:#f0e6c8;font-weight:700;margin:0 0 16px;">Practice Areas</h2>
                <p style="color:rgba(240,230,200,0.45);font-size:16px;max-width:480px;margin:0 auto;line-height:1.6;">Specialist legal expertise across every dimension of commercial law.</p>
              </div>
              <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;max-width:960px;margin:0 auto;">
                {[
                  { title:'Commercial Litigation', desc:'High-stakes disputes resolved through precision strategy and relentless advocacy. We represent boards, executives, and shareholders.', icon:'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2' },
                  { title:'Mergers & Acquisitions', desc:'Seamless transaction management from term sheet to close. Due diligence, deal structuring, and post-merger integration support.', icon:'M12 5v14M5 12h14' },
                  { title:'Employment Law', desc:'Protecting businesses across dismissals, contracts, restraint of trade, and enterprise bargaining agreements.', icon:'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z' },
                  { title:'Property & Construction', desc:'Development agreements, strata disputes, builder claims, and commercial leasing across all Australian states.', icon:'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
                  { title:'Intellectual Property', desc:'Trademark registration, IP licensing, trade secret protection, and enforcement of creative and technology assets.', icon:'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18' },
                  { title:'Insolvency & Restructuring', desc:'Creditor representation, voluntary administration, and corporate restructuring strategies that preserve value.', icon:'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
                ].map(area => (
                  <div style="background:#0d1525;border:1px solid rgba(201,168,76,0.1);border-radius:12px;padding:28px;display:flex;gap:18px;cursor:pointer;" class="law-card">
                    <div style="width:44px;height:44px;min-width:44px;background:rgba(201,168,76,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={area.icon}/></svg>
                    </div>
                    <div>
                      <h3 style="font-family:Georgia,serif;font-size:16px;color:#f0e6c8;font-weight:700;margin:0 0 8px;">{area.title}</h3>
                      <p style="color:rgba(240,230,200,0.45);font-size:13px;line-height:1.6;margin:0;">{area.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- ═══════════════════════════════ PAGE 2: OUR TEAM ═══════════════════════════════ -->
          <div class="law-page hidden" data-page="2">
            <nav style="background:#0a0e1a;border-bottom:1px solid rgba(201,168,76,0.15);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="law-logo">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#c9a84c,#8a6f2e);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M8 6h8M7 3h10"/></svg>
                </div>
                <span style="color:#f0e6c8;font-family:Georgia,serif;font-size:16px;font-weight:700;">Mercer & Partners</span>
              </div>
              <div style="display:flex;align-items:center;gap:24px;">
                {[{n:'Practice Areas',g:'1'},{n:'Our Team',g:'2'}].map(item=>(
                  <span style="color:rgba(240,230,200,0.55);font-size:13px;cursor:pointer;" class="law-nav-link" data-goto={item.g}>{item.n}</span>
                ))}
                <button style="background:linear-gradient(135deg,#c9a84c,#a8872e);color:#0a0e1a;font-size:12px;font-weight:700;padding:8px 18px;border-radius:6px;border:none;cursor:pointer;letter-spacing:0.04em;" class="law-nav-link" data-goto="3">Book a Consultation</button>
              </div>
            </nav>
            <div style="background:#080c18;padding:72px 48px;">
              <div style="text-align:center;margin-bottom:56px;">
                <p style="color:#c9a84c;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:10px;">The Firm</p>
                <h2 style="font-family:Georgia,serif;font-size:40px;color:#f0e6c8;font-weight:700;margin:0 0 16px;">Our Team</h2>
                <p style="color:rgba(240,230,200,0.45);font-size:16px;max-width:480px;margin:0 auto;line-height:1.6;">Senior practitioners with decades of commercial experience at the highest levels.</p>
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:960px;margin:0 auto;">
                {[
                  { name:'James Mercer', title:'Senior Partner', spec:'Commercial Litigation & M&A', initials:'JM', exp:'28 yrs', edu:'LLB (Hons) Melbourne, BCL Oxford' },
                  { name:'Catherine Rhodes', title:'Partner', spec:'Employment & Industrial Law', initials:'CR', exp:'19 yrs', edu:'LLB Monash, LLM Sydney' },
                  { name:'David Okafor', title:'Partner', spec:'Property & Construction Law', initials:'DO', exp:'16 yrs', edu:'LLB (Hons) ANU, BCom Melbourne' },
                  { name:'Sarah Whitfield', title:'Senior Associate', spec:'Intellectual Property', initials:'SW', exp:'11 yrs', edu:'LLB/BSc Melbourne' },
                  { name:'Thomas Liang', title:'Senior Associate', spec:'Insolvency & Restructuring', initials:'TL', exp:'9 yrs', edu:'LLB (Hons) UNSW' },
                  { name:'Priya Mehta', title:'Associate', spec:'Corporate & Commercial', initials:'PM', exp:'5 yrs', edu:'LLB/BBus Queensland' },
                ].map(p => (
                  <div style="background:#0d1525;border:1px solid rgba(201,168,76,0.1);border-radius:12px;padding:24px;cursor:pointer;" class="law-card">
                    <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#1a2a4a,#2a3a5a);border:2px solid rgba(201,168,76,0.25);display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
                      <span style="color:#c9a84c;font-size:15px;font-weight:700;">{p.initials}</span>
                    </div>
                    <h3 style="font-family:Georgia,serif;font-size:15px;color:#f0e6c8;font-weight:700;margin:0 0 2px;">{p.name}</h3>
                    <p style="color:#c9a84c;font-size:11px;font-weight:600;margin:0 0 6px;letter-spacing:0.04em;">{p.title}</p>
                    <p style="color:rgba(240,230,200,0.45);font-size:12px;margin:0 0 12px;line-height:1.5;">{p.spec}</p>
                    <div style="border-top:1px solid rgba(201,168,76,0.1);padding-top:10px;display:flex;justify-content:space-between;align-items:center;">
                      <span style="color:rgba(240,230,200,0.3);font-size:11px;">{p.edu}</span>
                      <span style="color:#c9a84c;font-size:11px;font-weight:600;">{p.exp}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- ═══════════════════════════════ PAGE 3: CONTACT ═══════════════════════════════ -->
          <div class="law-page hidden" data-page="3">
            <nav style="background:#0a0e1a;border-bottom:1px solid rgba(201,168,76,0.15);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" class="law-logo">
