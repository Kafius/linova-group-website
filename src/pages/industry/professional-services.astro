<script is:inline>
  const pages = document.querySelectorAll('.law-page');
  const viewport = document.getElementById('law-viewport');
  function goToPage(idx) {
    pages.forEach((p,i) => p.classList.toggle('hidden', i!==idx));
    if(viewport) viewport.scrollTop=0;
  }
  document.querySelectorAll('.law-nav-link[data-goto]').forEach(link => {
    link.addEventListener('click', () => goToPage(parseInt(link.dataset.goto)));
  });
  document.querySelectorAll('.law-logo').forEach(logo => {
    logo.addEventListener('click', () => goToPage(0));
  });
  document.querySelectorAll('.law-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.borderColor = 'rgba(201,168,76,0.35)';
      card.style.background = '#111d31';
    });
    card.addEventListener('mouseleave', () => {
      card.style.borderColor = 'rgba(201,168,76,0.1)';
      card.style.background = '#0d1525';
    });
  });
</script>
