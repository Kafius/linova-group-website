---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar/Navbar.astro';
import BeforeAfterSlider from '../components/services/BeforeAfterSlider.astro';
import AnalyticsShowcase from '../components/services/AnalyticsShowcase.astro';
import KeystaticShowcase from '../components/services/KeystaticShowcase.astro';
import Contact from '../components/contact/Contact.astro';
import Footer from '../components/footer/Footer.astro';

const services = [
  {
    title: 'Custom Website Design',
    description: 'Fully bespoke designs crafted to reflect your brand identity. We create pixel-perfect layouts that captivate your audience and drive conversions.',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
    features: ['Brand-aligned design', 'Custom UI components', 'Conversion-focused layouts', 'Wireframing & prototyping'],
  },
  {
    title: 'Web Development',
    description: 'High-performance websites built with modern technologies. Clean, maintainable code that loads fast and scales with your business.',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    features: ['Astro, Next.js, React', 'CMS integration', 'API & third-party integrations', 'Performance optimization'],
  },
  {
    title: 'E-Commerce Solutions',
    description: 'Turn browsers into buyers with a polished online store. We build fast, secure shops that make purchasing effortless.',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
    features: ['Shopify & WooCommerce', 'Secure payment gateways', 'Inventory management', 'Mobile-optimized checkout'],
  },
  {
    title: 'SEO & Performance',
    description: 'Get found online and keep visitors engaged. We optimize every aspect of your site so search engines and users love it.',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    features: ['On-page SEO', 'Core Web Vitals tuning', 'Structured data markup', 'Analytics setup'],
  },
  {
    title: 'Website Redesign',
    description: "Breathe new life into an outdated site. We modernize your existing presence while preserving your SEO equity and user base.",
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>',
    features: ['UX audit & improvements', 'Content migration', 'Brand refresh', 'Zero-downtime launch'],
  },
  {
    title: 'Maintenance & Support',
    description: "We stick around after launch. Ongoing updates, security patches, and priority support so your site keeps running at its best.",
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
    features: ['Monthly update plans', 'Security monitoring', 'Uptime guarantees', 'Priority turnaround'],
  },
];
---

<Layout
  title="Services — Linova Group"
  description="Explore the full range of web design and development services offered by Linova Group. Custom websites, e-commerce, SEO, and ongoing support."
>
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-36 pb-20 overflow-hidden text-white" style="background: linear-gradient(135deg, #16172f 0%, #26275E 50%, #1e1f4a 100%);">
    <div class="absolute inset-0 opacity-[0.045]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="absolute top-0 right-1/4 w-[520px] h-[320px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(96,165,250,0.07) 0%, transparent 70%); filter: blur(70px);"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[300px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(79,70,229,0.1) 0%, transparent 70%); filter: blur(60px);"></div>

    <div class="relative max-w-[1140px] mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/75 text-xs font-semibold tracking-[0.15em] uppercase px-4 py-2 rounded-full mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
        What We Offer
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-[3.75rem] font-extrabold tracking-tight leading-[1.07] mb-5">
        Services Built<br class="hidden sm:block" /> for Growth
      </h1>
      <p class="text-white/55 text-lg max-w-[560px] mx-auto leading-relaxed font-medium mb-10">
        From first concept to ongoing support, we handle every aspect of your web presence so you can focus on running your business.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-[0.95rem] bg-white text-primary hover:bg-white/90 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(255,255,255,0.2)] transition-all duration-200 cursor-pointer">
          Get a Free Quote
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#services-grid" class="inline-flex items-center justify-center px-7 py-3.5 rounded-xl font-semibold text-[0.95rem] border border-white/25 text-white hover:border-white/50 hover:bg-white/10 transition-all duration-200 cursor-pointer">
          Explore Services
        </a>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-28 bg-white" id="services-grid">
    <div class="max-w-[1140px] mx-auto px-6">
      <div class="text-center mb-16">
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3">Full Suite</span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark tracking-tight mb-3">Everything You Need Online</h2>
        <p class="text-muted text-lg max-w-[560px] mx-auto">From design to deployment, we handle every aspect of your digital presence.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map(service => (
          <div class="group relative bg-white border border-border rounded-2xl p-7 hover:border-primary/20 hover:shadow-[0_8px_32px_rgba(38,39,94,0.08)] hover:-translate-y-0.5 transition-all duration-300 cursor-default overflow-hidden">
            <div class="absolute inset-x-0 top-0 h-[2px] rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(90deg, #26275E, #4f51b5);"></div>
            <div class="w-12 h-12 bg-light text-primary rounded-xl flex items-center justify-center mb-5 group-hover:bg-primary group-hover:text-white transition-all duration-300">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-dark font-bold text-base mb-2">{service.title}</h3>
            <p class="text-muted text-sm leading-relaxed mb-5">{service.description}</p>
            <ul class="flex flex-col gap-1.5">
              {service.features.map(feature => (
                <li class="flex items-center gap-2 text-sm text-muted">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#26275E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <BeforeAfterSlider />
  <AnalyticsShowcase />
  <KeystaticShowcase />

  <!-- CTA Banner -->
  <section class="py-24 text-white text-center" style="background: linear-gradient(135deg, #16172f 0%, #26275E 60%, #1e1f4a 100%);">
    <div class="relative max-w-[1140px] mx-auto px-6">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="relative max-w-[600px] mx-auto">
        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-blue-300/70 mb-4">Let's Talk</span>
        <h2 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-4">Not Sure Where to Start?</h2>
        <p class="text-white/55 text-lg leading-relaxed mb-8">
          Tell us about your project and we'll recommend the right solution — no commitment required.
        </p>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-[0.95rem] bg-white text-primary hover:bg-white/90 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(255,255,255,0.15)] transition-all duration-200 cursor-pointer">
          Let's Talk
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <Contact />
  <Footer />
</Layout>
