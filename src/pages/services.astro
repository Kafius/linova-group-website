---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar/Navbar.astro';
import BeforeAfterSlider from '../components/services/BeforeAfterSlider.astro';
import Contact from '../components/contact/Contact.astro';
import Footer from '../components/footer/Footer.astro';

const services = [
  {
    title: 'Custom Website Design',
    description: 'Fully bespoke designs crafted to reflect your brand identity. We create pixel-perfect layouts that captivate your audience and drive conversions.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
    features: ['Brand-aligned design', 'Custom UI components', 'Conversion-focused layouts', 'Wireframing & prototyping'],
  },
  {
    title: 'Web Development',
    description: 'High-performance websites built with modern technologies. Clean, maintainable code that loads fast and scales with your business.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    features: ['Astro, Next.js, React', 'CMS integration', 'API & third-party integrations', 'Performance optimization'],
  },
  {
    title: 'E-Commerce Solutions',
    description: 'Turn browsers into buyers with a polished online store. We build fast, secure shops that make purchasing effortless.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
    features: ['Shopify & WooCommerce', 'Secure payment gateways', 'Inventory management', 'Mobile-optimized checkout'],
  },
  {
    title: 'SEO & Performance',
    description: 'Get found online and keep visitors engaged. We optimize every aspect of your site so search engines and users love it.',
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    features: ['On-page SEO', 'Core Web Vitals tuning', 'Structured data markup', 'Analytics setup'],
  },
  {
    title: 'Website Redesign',
    description: "Breathe new life into an outdated site. We modernize your existing presence while preserving your SEO equity and user base.",
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>',
    features: ['UX audit & improvements', 'Content migration', 'Brand refresh', 'Zero-downtime launch'],
  },
  {
    title: 'Maintenance & Support',
    description: "We stick around after launch. Ongoing updates, security patches, and priority support so your site keeps running at its best.",
    icon: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
    features: ['Monthly update plans', 'Security monitoring', 'Uptime guarantees', 'Priority turnaround'],
  },
];
---

<Layout
  title="Services — Linova Group"
  description="Explore the full range of web design and development services offered by Linova Group. Custom websites, e-commerce, SEO, and ongoing support."
>
  <Navbar />

  <!-- Hero -->
  <section class="pt-36 pb-20 bg-light">
    <div class="max-w-[1140px] mx-auto px-6 text-center">
      <span class="inline-block text-primary font-semibold text-sm tracking-widest uppercase mb-4">What We Offer</span>
      <h1 class="text-4xl lg:text-5xl font-bold text-dark tracking-tight mb-5">Services Built for Growth</h1>
      <p class="text-muted text-lg max-w-[620px] mx-auto mb-8">
        From first concept to ongoing support, we handle every aspect of your web presence so you can focus on running your business.
      </p>
      <a href="#contact" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold bg-primary text-white rounded-lg hover:bg-primary-hover transition-colors duration-200">
        Get a Free Quote
      </a>
    </div>
  </section>

  <BeforeAfterSlider />

  <!-- Services grid -->
  <section class="py-24">
    <div class="max-w-[1140px] mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <div class="bg-white border border-border rounded-2xl p-8 flex flex-col gap-5 hover:shadow-lg transition-shadow duration-300">
            <div class="w-14 h-14 bg-light text-primary rounded-xl inline-flex items-center justify-center flex-shrink-0">
              <Fragment set:html={service.icon} />
            </div>
            <div>
              <h2 class="text-dark font-bold text-lg mb-2">{service.title}</h2>
              <p class="text-muted text-sm leading-relaxed">{service.description}</p>
            </div>
            <ul class="flex flex-col gap-2 mt-auto">
              {service.features.map(f => (
                <li class="flex items-center gap-2 text-sm text-muted">
                  <svg class="text-primary flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="py-20 bg-primary">
    <div class="max-w-[1140px] mx-auto px-6 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight mb-4">Not sure where to start?</h2>
      <p class="text-white/80 text-lg max-w-[520px] mx-auto mb-8">
        Tell us about your project and we'll recommend the right solution — no commitment required.
      </p>
      <a href="#contact" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold bg-white text-primary rounded-lg hover:bg-light transition-colors duration-200">
        Let's Talk
      </a>
    </div>
  </section>

  <Contact />
  <Footer />
</Layout>
